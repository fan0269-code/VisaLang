---
const isZh = Astro.url.pathname.startsWith('/zh');
const isEnglishHome = Astro.url.pathname === '/';
const zhTranslationMap: Record<string, string> = {
  '/germany-family-reunion-a1/': '/zh/germany-family-reunion-a1/',
  '/guides/german-family-reunion-language-requirement/': '/zh/guides/german-family-reunion-language-requirement/',
  '/guides/goethe-a1-vs-telc-a1/': '/zh/guides/goethe-a1-vs-telc-a1/',
  '/guides/goethe-a1-booking-mistakes/': '/zh/guides/goethe-a1-booking-mistakes/',
  '/guides/german-a1-documents-checklist/': '/zh/guides/german-a1-documents-checklist/',
  '/guides/goethe-a1-30-day-study-plan/': '/zh/guides/goethe-a1-30-day-study-plan/',
};
const enTranslationMap = Object.fromEntries(
  Object.entries(zhTranslationMap).map(([enPath, zhPath]) => [zhPath, enPath])
);
const navLinks = isZh
  ? [
      { href: '/zh/', label: '首页' },
      { href: '/zh/germany-family-reunion-a1/', label: '德国 A1' },
      { href: '/zh/#zh-guides', label: '中文指南' },
      { href: '/about/', label: '关于' },
    ]
  : [
      { href: '/', label: 'Home' },
      { href: '/germany-family-reunion-a1/', label: 'Germany A1' },
      { href: '/guides/', label: 'Guides' },
      { href: '/about/', label: 'About' },
    ];
const languageSwitch = isZh
  ? { href: enTranslationMap[Astro.url.pathname] || '/', label: 'EN', aria: 'Switch to English', title: 'Switch to English' }
  : isEnglishHome
    ? { href: '/zh/', label: '中文', aria: 'Switch to Chinese', title: '切换中文' }
    : zhTranslationMap[Astro.url.pathname]
      ? { href: zhTranslationMap[Astro.url.pathname], label: '中文', aria: 'Switch to Chinese', title: '切换中文' }
    : { href: '/zh/', label: '中文首页', aria: 'Open Chinese homepage', title: 'Open Chinese homepage' };
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">VisaLang</a>
    <nav class="header-nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a href={link.href} class:list={[{ active: Astro.url.pathname === link.href || (link.href === '/guides/' && Astro.url.pathname.startsWith('/guides/')) }]}>
          {link.label}
        </a>
      ))}
    </nav>
    <a href={languageSwitch.href} class="lang-switch" aria-label={languageSwitch.aria} title={languageSwitch.title}>{languageSwitch.label}</a>
  </div>
</header>
