---
import { navItems, site, ui, type Locale } from '../data/site';
export interface Props { locale: Locale; switchHref: string; }
const { locale, switchHref } = Astro.props;
const labels = ui[locale];
const isZh = locale === 'zh-CN';
const currentPath = Astro.url.pathname;
const localHref = (href: string) => isZh && href === '/' ? '/zh/' : href;
const currentTopLevel = (key: string, href: string) => {
  if (key === 'routes') return currentPath === href;
  if (key === 'about') return ['/about/', '/pricing/', '/partners/'].some((path) => currentPath.startsWith(path));
  return href === '/' || href === '/zh/' ? currentPath === href : currentPath.startsWith(href);
};
---

<details class="mobile-navigation">
  <summary>{labels.menu}</summary>
  <nav aria-label={isZh ? '移动端导航' : 'Mobile navigation'}>
    {navItems.map((item) => { const href = localHref(item.href); return <a href={href} aria-current={currentTopLevel(item.key, href) ? 'page' : undefined}>{labels[item.key]}{isZh && item.key !== 'home' ? '（英文）' : ''}</a>; })}
    <div class="mobile-navigation__routes">
      {site.routes.map((route) => { const href = isZh && route.id === 'family-reunion' ? '/zh/germany-family-reunion-a1/' : route.href; return <a href={href} aria-current={currentPath === href ? 'page' : undefined}>{isZh ? `${route.zh}${route.id === 'family-reunion' ? '' : '（英文）'}` : route.label}</a>; })}
    </div>
    <a href={switchHref} hreflang={isZh ? 'en' : 'zh-CN'}>{isZh ? 'English' : '中文'}</a>
  </nav>
</details>
