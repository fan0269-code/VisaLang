---
import { navItems, site, ui, type Locale } from '../data/site';
import { navigationCurrent } from '../lib/navigation-current';
export interface Props { locale: Locale; switchHref: string; }
const { locale, switchHref } = Astro.props;
const labels = ui[locale];
const isZh = locale === 'zh-CN';
const currentPath = Astro.url.pathname;
const localHref = (href: string) => isZh && href === '/' ? '/zh/' : href;
---

<details class="mobile-navigation">
  <summary>{labels.menu}</summary>
  <nav aria-label={isZh ? '移动端导航' : 'Mobile navigation'}>
    {navItems.map((item) => { const href = localHref(item.href); return <a href={href} aria-current={navigationCurrent(currentPath, item.key, href)}>{labels[item.key]}{isZh && item.key !== 'home' ? '（英文）' : ''}</a>; })}
    <div class="mobile-navigation__routes">
      {site.routes.map((route) => { const href = isZh && route.id === 'family-reunion' ? '/zh/germany-family-reunion-a1/' : route.href; return <a href={href} aria-current={navigationCurrent(currentPath, 'route-item', href)}>{isZh ? `${route.zh}${route.id === 'family-reunion' ? '' : '（英文）'}` : route.label}</a>; })}
    </div>
    <a href={switchHref} hreflang={isZh ? 'en' : 'zh-CN'}>{isZh ? 'English' : '中文'}</a>
  </nav>
</details>
