---
export interface Props {
  headings: { text: string; id: string }[];
}
const { headings } = Astro.props;
---

{headings.length > 0 && (
  <aside class="guide-toc" aria-label="Table of contents">
    <h2>On this page</h2>
    <ol>
      {headings.map(h => (<li><a href={`#${h.id}`}>{h.text}</a></li>))}
    </ol>
  </aside>
)}
