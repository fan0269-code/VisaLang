---
import { toolLinks } from '../../data/route-tools';
import ToolStepper from '../ToolStepper.astro';

export interface Props {
  eyebrow: string;
  title: string;
  description: string;
  current: 'finder' | 'checklist' | 'timeline' | 'comparison' | 'reminders';
}

const { eyebrow, title, description, current } = Astro.props;
const toolNav = [
  { id: 'finder', label: 'Route Finder', href: toolLinks.finder },
  { id: 'checklist', label: 'Checklist', href: toolLinks.checklist },
  { id: 'timeline', label: 'Timeline', href: toolLinks.timeline },
  { id: 'comparison', label: 'Compare exams', href: toolLinks.comparison },
  { id: 'reminders', label: 'Reminders', href: toolLinks.reminders },
];
---

<main class="page-shell tool-page">
  <header class="tool-page-header">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{description}</p>
  </header>
  <nav class="tool-nav" aria-label="Decision tools">
    {toolNav.map((tool) => <a class:list={[{ active: tool.id === current }]} href={tool.href}>{tool.label}</a>)}
  </nav>
  <ToolStepper current={1} labels={['Understand the scope', 'Enter verified facts', 'Review and export']} />
  <slot />
  <div class="button-row"><button class="button button--secondary" type="button" data-tool-restart>Restart this tool</button></div>
</main>

<script>
  const form = document.querySelector<HTMLFormElement>('.tool-form');
  const restart = document.querySelector<HTMLButtonElement>('[data-tool-restart]');
  const storageKey = `visalang-tool:${location.pathname}`;
  if (form) {
    try {
      const saved = JSON.parse(localStorage.getItem(storageKey) || '{}');
      Object.entries(saved).forEach(([name, value]) => {
        const field = form.elements.namedItem(name);
        if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement || field instanceof HTMLTextAreaElement) field.value = String(value);
      });
    } catch {}
    form.addEventListener('input', () => {
      const values = Object.fromEntries(new FormData(form).entries());
      localStorage.setItem(storageKey, JSON.stringify(values));
    });
  }
  restart?.addEventListener('click', () => {
    localStorage.removeItem(storageKey);
    form?.reset();
    document.querySelectorAll<HTMLElement>('.tool-result, .tool-result-panel').forEach((result) => result.hidden = true);
    history.replaceState(null, '', location.pathname);
    form?.querySelector<HTMLElement>('input, select, textarea')?.focus();
  });
</script>
