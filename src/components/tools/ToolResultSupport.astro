---
import CopyButton from '../CopyButton.astro';
import PrintButton from '../PrintButton.astro';
import ExportButton from '../ExportButton.astro';
import { toolLinks } from '../../data/route-tools';

export interface Props {
  resultId: string;
  guideHref?: string;
  guideLabel?: string;
}

const { resultId, guideHref = '/guides/', guideLabel = 'Browse route guides' } = Astro.props;
---

<div class="tool-result-support">
  <div class="tool-notice">
    <strong>Informational guidance only.</strong> This tool organises planning questions; it does not decide visa eligibility, certificate acceptance, exam availability, or an individual application outcome.
  </div>
  <div class="tool-support-grid">
    <section>
      <h2>Official check before you act</h2>
      <p>Confirm the exact requirement, accepted certificate, documents, date, fee, result process, and local centre rules with the authority or official centre that receives your file.</p>
    </section>
    <section>
      <h2>Continue your plan</h2>
      <p><a href={guideHref}>{guideLabel}</a></p>
      <p><a href={toolLinks.checklist}>Open Checklist</a> / <a href={toolLinks.timeline}>Open Timeline</a></p>
    </section>
  </div>
  <div class="tool-cta-row"><CopyButton target={`#${resultId}`} /><PrintButton label="Print plan" /><ExportButton target={`#${resultId}`} /></div>
</div>
