---
import MobileNavigation from './MobileNavigation.astro';
import { navItems, site, translatedPaths, ui } from '../data/site';
import { navigationCurrent } from '../lib/navigation-current';

const isZh = Astro.url.pathname.startsWith('/zh');
const locale = isZh ? 'zh-CN' : 'en';
const labels = ui[locale];
const translations = translatedPaths;
const reverseTranslations = Object.fromEntries(Object.entries(translatedPaths).map(([en, zh]) => [zh, en]));
const switchHref = isZh ? reverseTranslations[Astro.url.pathname] || '/' : translations[Astro.url.pathname] || '/zh/';
const localHref = (href: string) => isZh && href === '/' ? '/zh/' : href;
const navLabel = (key: keyof typeof labels) => `${labels[key]}${isZh && key !== 'home' ? '（英文）' : ''}`;
const currentPath = Astro.url.pathname;
---

<header class="global-header" data-global-header>
  <div class="global-header__inner">
    <a class="global-header__brand" href={isZh ? '/zh/' : '/'} aria-label={`${site.name} ${labels.home}`}>
      <img class="global-header__mark" src="/brand/logo-mark.svg" alt="" width="28" height="28" aria-hidden="true">
      Visa<span>Lang</span>
    </a>
    <nav class="global-header__nav" aria-label={isZh ? '主导航' : 'Primary navigation'}>
      {navItems.map((item) => {
        const href = localHref(item.href);
        const current = navigationCurrent(currentPath, item.key, href);
        const active = Boolean(current);
        if (item.key === 'routes') {
          return (
            <div class="nav-menu">
              <a class:list={['nav-menu__link', { active }]} href={href} aria-current={current}>{navLabel('routes')}</a>
              <details class="nav-menu__disclosure">
                <summary aria-label={isZh ? '打开路线菜单' : 'Open Routes menu'}></summary>
                <div class="nav-menu__panel">
                  {site.routes.map((route) => { const routeHref = isZh && route.id === 'family-reunion' ? '/zh/germany-family-reunion-a1/' : route.href; return <a href={routeHref} aria-current={navigationCurrent(currentPath, 'route-item', routeHref)}>{isZh ? `${route.zh}${route.id === 'family-reunion' ? '' : '（英文）'}` : route.label}</a>; })}
                </div>
              </details>
            </div>
          );
        }
        if (item.key === 'about') {
          return (
            <div class="nav-menu">
              <a class:list={['nav-menu__link', { active }]} href={href} aria-current={current}>{navLabel('about')}</a>
              <details class="nav-menu__disclosure">
                <summary aria-label={isZh ? '打开关于菜单' : 'Open About menu'}></summary>
                <div class="nav-menu__panel">
                  <a href="/about/" aria-current={navigationCurrent(currentPath, 'about-item', '/about/')}>{isZh ? '关于（英文）' : labels.about}</a>
                  <a href="/pricing/" aria-current={navigationCurrent(currentPath, 'about-item', '/pricing/')}>{isZh ? '价格与服务状态（英文）' : 'Pricing'}</a>
                  <a href="/partners/" aria-current={navigationCurrent(currentPath, 'about-item', '/partners/')}>{isZh ? '合作伙伴（英文）' : 'Partners'}</a>
                </div>
              </details>
            </div>
          );
        }
        return <a class:list={[{ active }]} href={href} aria-current={current}>{navLabel(item.key)}</a>;
      })}
    </nav>
    <a class="language-switch" href={switchHref} hreflang={isZh ? 'en' : 'zh-CN'}>{isZh ? 'English' : '中文'}</a>
    <a class="header-route-cta" href="/tools/route-finder/">{isZh ? '查找路线' : 'Find my route'} <span aria-hidden="true">→</span></a>
    <MobileNavigation locale={locale} switchHref={switchHref} />
  </div>
</header>
