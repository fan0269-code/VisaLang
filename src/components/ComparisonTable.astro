---
export interface Props { caption: string; columns: string[]; rows: { label: string; values: string[] }[]; }
const { caption, columns, rows } = Astro.props;
---
<div class="responsive-table" tabindex="0" role="region" aria-label={`${caption}. Scroll horizontally on small screens.`}><table><caption>{caption}</caption><thead><tr><th scope="col">Decision</th>{columns.map((column) => <th scope="col">{column}</th>)}</tr></thead><tbody>{rows.map((row) => <tr><th scope="row">{row.label}</th>{row.values.map((value) => <td data-label={row.label}>{value}</td>)}</tr>)}</tbody></table></div>
