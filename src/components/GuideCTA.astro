---
export interface Props {
  title?: string; text?: string; buttonLabel?: string; buttonHref?: string;
}
const {
  title = 'Need help picking the right exam?',
  text = 'Send us the route you are checking and we will use official sources when prioritising future guide updates.',
  buttonLabel = 'Contact VisaLang',
  buttonHref = '/contact/',
} = Astro.props;
---

<section class="guide-cta" aria-label="Get updates">
  <h2>{title}</h2>
  <p>{text}</p>
  <a class="primary-action" href={buttonHref}>{buttonLabel}</a>
</section>
