---
interface RelatedGuide { title: string; slug: string; }
export interface Props {
  guides: RelatedGuide[];
  routeHref?: string;
  routeLabel?: string;
  previous?: RelatedGuide;
  next?: RelatedGuide;
}
const { guides, routeHref, routeLabel = 'this route', previous, next } = Astro.props;
---

{(guides.length > 0 || routeHref || previous || next) && (
  <section class="guide-related" aria-label="Next guides in this journey">
    {(previous || next) && <nav class="guide-sequence" aria-label="Previous and next guides">{previous && <a href={`/guides/${previous.slug}/`}><small>Previous guide</small><strong>{previous.title}</strong></a>}{next && <a href={`/guides/${next.slug}/`}><small>Next guide</small><strong>{next.title}</strong></a>}</nav>}
    <h2>Continue this journey</h2>
    <p>Use the next guide that matches your route or decision stage.</p>
    {guides.length > 0 && (
      <div class="guide-related-grid">
        {guides.map(g => (<a href={`/guides/${g.slug}/`}>{g.title}</a>))}
      </div>
    )}
    {routeHref && (
      <a class="route-backlink" href={routeHref}>Browse all guides in {routeLabel}</a>
    )}
  </section>
)}
