---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TOC from '../components/TOC.astro';
import RelatedGuides from '../components/RelatedGuides.astro';
import GuideCTA from '../components/GuideCTA.astro';

export interface Props {
  title: string;
  description: string;
  publishedDate: string;
  updatedDate: string;
  slug: string;
  category?: string;
  route?: string;
  eyebrow?: string;
  breadcrumbs?: { label: string; href?: string }[];
  related?: { title: string; slug: string }[];
  headings?: { slug: string; text: string }[];
}

const {
  title,
  description,
  publishedDate,
  updatedDate,
  slug,
  eyebrow,
  breadcrumbs = [
    { label: 'Home', href: '/' },
    { label: title },
  ],
  related = [],
  headings = [],
} = Astro.props;

const tocHeadings = headings.map(h => ({ text: h.text, id: h.slug }));

const canonicalURL = `https://flowlight.me/guides/${slug}.html`;

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  url: canonicalURL,
  datePublished: publishedDate,
  dateModified: updatedDate,
  publisher: { '@type': 'Organization', name: 'VisaLang', url: 'https://flowlight.me/' },
  about: description,
  inLanguage: 'en',
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  jsonLD={jsonLD}
>
  <main class="guide-page">
    <Breadcrumbs path={breadcrumbs} />
    <div class="guide-layout">
      <TOC headings={tocHeadings} />
      <article class="guide-article">
        <div class="guide-hero-icon" aria-hidden="true">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="9" r="5"/><path d="M9 13.5 8 22l4-2 4 2-1-8.5"/>
          </svg>
        </div>
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <p class="guide-summary">{description}</p>
        <slot />
      </article>
    </div>
    <RelatedGuides guides={related} />
    <GuideCTA />
  </main>
</BaseLayout>
