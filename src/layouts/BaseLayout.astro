---
import GlobalHeader from '../components/GlobalHeader.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import { organisationJsonLD, site, ui } from '../data/site';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  lang?: string;
  alternates?: { lang: string; href: string }[];
  jsonLD?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Find the right language exam for your visa, residency, citizenship, or work-registration path.',
  canonicalURL = Astro.url.href,
  ogImage = '/images/og-default.svg',
  ogType = 'website',
  noindex = false,
  lang = 'en',
  alternates = [],
  jsonLD,
} = Astro.props;

const pageTitle = /(^|\s|\|)VisaLang($|\s)/i.test(title) ? title : `${title} | VisaLang`;
const absoluteOgImage = new URL(ogImage, site.url).href;
const locale = lang.startsWith('zh') ? 'zh-CN' : 'en';
const structuredData = [
  { '@context': 'https://schema.org', ...organisationJsonLD },
  ...(Array.isArray(jsonLD) ? jsonLD : jsonLD ? [jsonLD] : []),
];
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{pageTitle}</title>
  <meta name="description" content={description}>
  {noindex && <meta name="robots" content="noindex,follow">}
  <link rel="canonical" href={canonicalURL}>
  {alternates.map((alternate) => (
    <link rel="alternate" hreflang={alternate.lang} href={alternate.href}>
  ))}
  <meta property="og:title" content={pageTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:type" content={ogType}>
  <meta property="og:image" content={absoluteOgImage}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={pageTitle}>
  <meta name="twitter:description" content={description}>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3018617123550799" crossorigin="anonymous"></script>
  {structuredData.map((data) => <script type="application/ld+json" set:html={JSON.stringify(data)}></script>)}
</head>
<body>
  <a class="skip-link" href="#main-content">{ui[locale].skip}</a>
  <GlobalHeader />
  <div id="main-content" tabindex="-1"><slot /></div>
  <GlobalFooter />
  <script is:inline>
    document.querySelectorAll('.nav-menu').forEach((menu) => {
      menu.addEventListener('toggle', () => {
        if (!menu.open) return;
        document.querySelectorAll('.nav-menu[open]').forEach((other) => { if (other !== menu) other.removeAttribute('open'); });
      });
    });
  </script>
</body>
</html>
