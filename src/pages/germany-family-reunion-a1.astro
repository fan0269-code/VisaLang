---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHero from '../components/PageHero.astro';
import RouteProgress from '../components/RouteProgress.astro';
import VerificationAlert from '../components/VerificationAlert.astro';
import LastCheckedBadge from '../components/LastCheckedBadge.astro';
import SourceCard from '../components/SourceCard.astro';
import ReportOutdatedInfo from '../components/ReportOutdatedInfo.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).filter((guide) => guide.data.category === 'germany-a1');
const updatedDate = guides.reduce((latest, guide) => guide.data.updatedDate > latest ? guide.data.updatedDate : latest, '2026-07-11');
const steps = [
  { title: 'Confirm whether A1 applies', status: 'current', preparation: 'Your application location, family-reunion category, receiving German mission or authority, and any exemption question.', guide: { href: '/guides/german-family-reunion-language-requirement/', label: 'Requirement guide' }, tool: { href: '/tools/route-finder/', label: 'Route Finder' } },
  { title: 'Confirm the accepted proof', status: 'next', preparation: 'The exact adult certificate, level, exam version, and document format named by the responsible authority.', guide: { href: '/guides/goethe-a1-germany-family-reunion/', label: 'Accepted proof guide' }, tool: { href: '/tools/checklist-generator/', label: 'Requirement Checklist' } },
  { title: 'Compare exam options', status: 'next', preparation: 'Goethe A1 and telc A1 as verification options, not as assumed acceptance or provider rankings.', guide: { href: '/guides/goethe-a1-vs-telc-a1/', label: 'Goethe vs telc' }, tool: { href: '/tools/exam-comparison/', label: 'Exam Comparison' } },
  { title: 'Verify centre and booking', status: 'next', preparation: 'Authorised centre status, exact exam, ID, fee, date, cancellation, result, and certificate delivery.', guide: { href: '/guides/goethe-a1-booking-mistakes/', label: 'Booking checks' }, tool: { href: '/tools/checklist-generator/', label: 'Booking checklist' } },
  { title: 'Build the timeline', status: 'next', preparation: 'Only use result, delivery, translation, and retake buffers confirmed for the local route.', guide: { href: '/guides/german-a1-exam-booking-timeline/', label: 'Timeline guide' }, tool: { href: '/tools/timeline-calculator/', label: 'Timeline Planner' } },
  { title: 'Prepare documents and exam', status: 'next', preparation: 'Keep exam-day ID and booking evidence separate from the visa-file language certificate requirements.', guide: { href: '/guides/german-a1-documents-checklist/', label: 'Documents guide' }, tool: { href: '/tools/checklist-generator/', label: 'Document checklist' } },
  { title: 'Recheck before submission', status: 'next', preparation: 'Confirm the receiving authority still accepts the proof and that every required document format is current.', guide: { href: '/guides/german-a1-family-reunion-faq/', label: 'Route FAQ' }, tool: { href: '/tools/email-reminders/', label: 'Reminder Planner' } },
] as const;
const jsonLD = { '@context': 'https://schema.org', '@graph': [
  { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://flowlight.me/' }, { '@type': 'ListItem', position: 2, name: 'Routes', item: 'https://flowlight.me/routes/' }, { '@type': 'ListItem', position: 3, name: 'Germany A1 family reunion', item: 'https://flowlight.me/germany-family-reunion-a1/' }] },
  { '@type': 'FAQPage', mainEntity: [
    { '@type': 'Question', name: 'Do I need German A1 for family reunion?', acceptedAnswer: { '@type': 'Answer', text: 'The requirement and any exemption depend on the individual route and responsible authority. Confirm before booking.' } },
    { '@type': 'Question', name: 'Should I choose an exam before checking the requirement?', acceptedAnswer: { '@type': 'Answer', text: 'No. Confirm whether proof is required and which exact certificate is accepted first.' } },
  ] },
] };
---

<BaseLayout title="Germany A1 family reunion route" description="Confirm the Germany family-reunion A1 requirement, accepted proof, exam option, booking, timeline, documents, and official submission checks." canonicalURL="https://flowlight.me/germany-family-reunion-a1/" alternates={[{ lang: 'en', href: 'https://flowlight.me/germany-family-reunion-a1/' }, { lang: 'zh-CN', href: 'https://flowlight.me/zh/germany-family-reunion-a1/' }, { lang: 'x-default', href: 'https://flowlight.me/germany-family-reunion-a1/' }]} jsonLD={jsonLD}>
  <main class="site-main">
    <Breadcrumbs path={[{ label: 'Home', href: '/' }, { label: 'Routes', href: '/routes/' }, { label: 'Germany A1 family reunion' }]} />
    <PageHero compact eyebrow="Germany / Family reunion" title="Germany A1 family reunion route" description="Confirm whether A1 applies, then move through proof, exam, booking, timing, documents, and submission checks." primary={{ href: '#route-progress', label: 'Start the route' }} secondary={{ href: '/tools/route-finder/', label: 'Check my starting point' }} />
    <div class="card-footer"><LastCheckedBadge date={updatedDate} label="Route content updated" /><span class="last-checked">Official verification date not separately recorded</span><span>{guides.length} supporting guides</span></div>
    <VerificationAlert title="Who this route is for"><p>Use this route if you are preparing a German spouse or family-reunion application and still need to organise the language-proof decision. It cannot determine whether an exemption or certificate applies to your individual case.</p></VerificationAlert>

    <section id="route-progress" class="content-section" aria-labelledby="progress-title"><div class="section-header"><h2 id="progress-title">Your 7-step route</h2><p>Your current step is stored in this browser. Move forward only when the responsible source gives you enough information for the next decision.</p></div><RouteProgress steps={steps} current={0} routeId="germany-family-reunion-a1" /></section>

    <section class="content-section" aria-labelledby="recommended-tools"><div class="section-header"><h2 id="recommended-tools">Recommended tools</h2><p>Tools save your planning work locally and never turn an unsupported route into a result.</p></div><div class="tool-grid"><a class="article-card" href="/tools/route-finder/"><h3>Route Finder</h3><p class="card-meta">Start with the requirement and receiving authority.</p></a><a class="article-card" href="/tools/checklist-generator/"><h3>Requirement Checklist</h3><p class="card-meta">Track confirmed evidence and unresolved checks.</p></a><a class="article-card" href="/tools/timeline-calculator/"><h3>Timeline Planner</h3><p class="card-meta">Use only locally verified timing inputs.</p></a><a class="article-card" href="/tools/email-reminders/"><h3>Reminder Planner</h3><p class="card-meta">Create a calendar or printable recheck reminder.</p></a></div></section>

    <section class="content-section" aria-labelledby="route-guides"><div class="section-header"><h2 id="route-guides">Related guides</h2><p>Read in route order, not as a random article list.</p></div><div class="guide-related-grid">{guides.sort((a, b) => b.data.updatedDate.localeCompare(a.data.updatedDate)).slice(0, 8).map((guide) => <a class="article-card" href={`/guides/${guide.data.slug}/`}><h3>{guide.data.title}</h3><p class="card-meta">{guide.data.description}</p><LastCheckedBadge date={guide.data.updatedDate} /></a>)}</div><div class="button-row"><a class="button button--secondary" href="/guides/category/germany-a1/">View all Germany A1 guides</a></div></section>

    <section class="content-section" aria-labelledby="official-entry"><div class="section-header"><h2 id="official-entry">Official verification entry points</h2><p>Start with the authority for the route, then use exam-owner and authorised-centre information for the booking. This route does not currently record a separate source-check date.</p></div><div class="guide-related-grid"><SourceCard name="BAMF family reunification" href="https://www.bamf.de/EN/Themen/MigrationAufenthalt/ZuwandererDrittstaaten/Familie/familie-node.html" /><SourceCard name="German Federal Foreign Office" href="https://www.auswaertiges-amt.de/en" /><SourceCard name="Goethe-Institut examinations" href="https://www.goethe.de/en/spr/prf.html" /><SourceCard name="telc Deutsch A1" href="https://www.telc.net/en/language-examinations/certificate-exams/german/start-german1-telc-german-a1/" /></div></section>

    <section class="content-section" aria-labelledby="route-faq"><div class="section-header"><h2 id="route-faq">Route FAQ</h2></div><details><summary>Do I need German A1 for family reunion?</summary><p>The requirement and any exemption depend on the individual route and responsible authority. Confirm before booking.</p></details><details><summary>Should I choose an exam before checking the requirement?</summary><p>No. Confirm whether proof is required and which exact certificate is accepted first.</p></details></section>
    <ReportOutdatedInfo pageTitle="Germany A1 family reunion route" />
  </main>
</BaseLayout>
