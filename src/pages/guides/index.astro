---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import GuideCard from '../../components/GuideCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import SearchInput from '../../components/SearchInput.astro';
import { getCollection } from 'astro:content';
import { guideCategories, guideMaturityStatus, inferGuideMeta } from '../../data/guide-taxonomy';
import { zhGermanyA1Guides } from '../../data/zh-germany-a1';

const guidePurpose = (route: string) => {
  const value = route.toLowerCase();
  if (value.includes('family')) return 'Family reunion';
  if (value.includes('university') || value.includes('study')) return 'Study';
  if (value.includes('work') || value.includes('nursing')) return 'Work';
  if (value.includes('settlement') || value.includes('integration') || value.includes('residence')) return 'Settlement';
  if (value.includes('citizenship')) return 'Citizenship';
  return 'Route research';
};
const guides = (await getCollection('guides')).map((guide) => {
  const meta = inferGuideMeta(guide.data);
  return { ...guide, meta, purpose: guidePurpose(meta.route), status: guideMaturityStatus(guide.data.category) };
}).sort((a, b) => b.data.updatedDate.localeCompare(a.data.updatedDate));
const options = (values: string[]) => Array.from(new Set(values)).sort().map((value) => ({ value, label: value }));
const filters = [
  { name: 'purpose', label: 'Purpose', options: options(guides.map((guide) => guide.purpose)) },
  { name: 'country', label: 'Country', options: options(guides.map((guide) => guide.meta.country)) },
  { name: 'route', label: 'Route', options: guideCategories.map((category) => ({ value: category.slug, label: category.name })) },
  { name: 'exam', label: 'Exam', options: options(guides.flatMap((guide) => guide.meta.exam.split(' / '))) },
  { name: 'level', label: 'Level', options: options(guides.map((guide) => guide.meta.level)) },
  { name: 'language', label: 'Language', options: [{ value: 'en', label: 'English' }, { value: 'zh', label: '中文' }] },
  { name: 'status', label: 'Content status', options: [{ value: 'complete-route', label: 'Complete route' }, { value: 'core-route', label: 'Core route' }, { value: 'starter', label: 'Starter overview' }] },
];
const totalGuideCount = guides.length + zhGermanyA1Guides.length;
const jsonLD = { '@context': 'https://schema.org', '@graph': [{ '@type': 'CollectionPage', name: 'VisaLang task guide library', url: 'https://flowlight.me/guides/', mainEntity: { '@id': 'https://flowlight.me/guides/#items' } }, { '@type': 'ItemList', '@id': 'https://flowlight.me/guides/#items', numberOfItems: totalGuideCount, itemListElement: [...guides.map((guide, index) => ({ '@type': 'ListItem', position: index + 1, name: guide.data.title, url: `https://flowlight.me/guides/${guide.data.slug}/` })), ...zhGermanyA1Guides.map((guide, index) => ({ '@type': 'ListItem', position: guides.length + index + 1, name: guide.title, url: `https://flowlight.me${guide.href}` }))] }] };
---

<BaseLayout title="Task guide library" description="Filter language-proof guides by purpose, country, route, exam, level, language, and content status." canonicalURL="https://flowlight.me/guides/" jsonLD={jsonLD}>
  <main class="site-main od-guide-library">
    <PageHero compact eyebrow="Task library" title="Find the guide for your next decision." description="Germany A1 is the complete route, Germany B1 is a core route, and other pages are starter overviews for official checks." />
    <section class="library-panel" aria-label="Guide filters">
      <SearchInput />
      <FilterBar filters={filters} />
      <label class="search-input" for="guide-sort"><span>Sort by</span><select id="guide-sort" data-guide-sort><option value="checked">Recently verified</option><option value="relevance">Route relevance</option><option value="maturity">Content maturity</option></select></label>
      <p class="filter-status" aria-live="polite">Showing {totalGuideCount} guides.</p>
    </section>
    <section class="content-section" aria-label="Guide results"><div class="guide-related-grid" id="guide-grid">{guides.map((guide, index) => <div class="guide-card-wrap" data-title={guide.data.title.toLowerCase()} data-search={`${guide.data.title} ${guide.data.description} ${guide.purpose} ${guide.meta.country} ${guide.meta.route} ${guide.meta.exam} ${guide.meta.level}`.toLowerCase()} data-purpose={guide.purpose} data-country={guide.meta.country} data-route={guide.data.category} data-exam={guide.meta.exam} data-level={guide.meta.level} data-language="en" data-status={guide.status} data-checked={guide.data.updatedDate} data-relevance={guide.data.category === 'germany-a1' ? 3 : guide.data.category === 'germany-b1' ? 2 : 1} data-maturity={guide.status === 'complete-route' ? 3 : guide.status === 'core-route' ? 2 : 1} data-original={index}><GuideCard title={guide.data.title} href={`/guides/${guide.data.slug}/`} value={guide.data.description} country={guide.meta.country} purpose={guide.purpose} exam={guide.meta.exam} level={guide.meta.level} status={guide.status} checked={guide.data.updatedDate} readingTime={guide.data.readingTime} /></div>)}{zhGermanyA1Guides.map((guide, index) => <div class="guide-card-wrap" data-title={guide.title.toLowerCase()} data-search={`${guide.title} ${guide.description} 德国 家庭团聚 A1 中文` } data-purpose="Family reunion" data-country="Germany" data-route="germany-a1" data-exam="German A1" data-level="A1" data-language="zh" data-status="complete-route" data-checked="2026-07-09" data-relevance="3" data-maturity="3" data-original={guides.length + index}><GuideCard title={guide.title} href={guide.href} value={guide.description} country="Germany" purpose="Family reunion" exam="German A1" level="A1" status="complete-route" checked="2026-07-09" readingTime="6" language="中文" /></div>)}</div><div class="guide-empty-state" hidden><h2>No matching guide</h2><p>Clear a narrow filter or start with Purpose and Country. If your route is not supported, use Route Finder to prepare an official check.</p><a class="button button--secondary" href="/tools/route-finder/">Open Route Finder</a></div></section>
  </main>
  <script is:inline>
    (() => {
      const params = new URLSearchParams(location.search);
      const grid = document.querySelector('#guide-grid');
      const cards = [...document.querySelectorAll('.guide-card-wrap')];
      const search = document.querySelector('[data-guide-search]');
      const filters = [...document.querySelectorAll('[data-guide-filter]')];
      const sort = document.querySelector('[data-guide-sort]');
      const form = document.querySelector('[data-filter-form]');
      const status = document.querySelector('.filter-status');
      const empty = document.querySelector('.guide-empty-state');
      const drawer = document.querySelector('.filter-drawer');
      if (matchMedia('(max-width: 680px)').matches) drawer?.removeAttribute('open');
      const syncUrl = () => {
        const next = new URLSearchParams();
        if (search.value.trim()) next.set('q', search.value.trim());
        filters.forEach((filter) => { if (filter.value) next.set(filter.name, filter.value); });
        if (sort.value !== 'checked') next.set('sort', sort.value);
        history.replaceState(null, '', next.toString() ? `/guides/?${next}` : '/guides/');
      };
      const apply = () => {
        const query = search.value.trim().toLowerCase();
        let visible = 0;
        cards.forEach((card) => {
          const matchesSearch = !query || card.dataset.search.includes(query);
          const matchesFilters = filters.every((filter) => {
            if (!filter.value) return true;
            if (filter.name === 'exam') return card.dataset.exam.split(' / ').includes(filter.value);
            return card.dataset[filter.name] === filter.value;
          });
          card.hidden = !(matchesSearch && matchesFilters);
          if (!card.hidden) visible += 1;
        });
        const key = sort.value;
        const sorted = [...cards].sort((a, b) => key === 'checked' ? b.dataset.checked.localeCompare(a.dataset.checked) : Number(b.dataset[key]) - Number(a.dataset[key]) || Number(a.dataset.original) - Number(b.dataset.original));
        sorted.forEach((card) => grid.append(card));
        status.textContent = `Showing ${visible} of ${cards.length} guides.`;
        empty.hidden = visible !== 0;
        syncUrl();
      };
      search.value = params.get('q') || '';
      filters.forEach((filter) => { filter.value = params.get(filter.name) || ''; });
      sort.value = params.get('sort') || 'checked';
      search.addEventListener('input', apply);
      filters.forEach((filter) => filter.addEventListener('change', apply));
      sort.addEventListener('change', apply);
      form.addEventListener('reset', () => setTimeout(() => { search.value = ''; sort.value = 'checked'; apply(); }, 0));
      apply();
    })();
  </script>
</BaseLayout>
