---
import { getCollection } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';
import { formatRouteLabel, inferGuideMeta } from '../../data/guide-taxonomy';
import { buildArticleSections } from '../../data/article-sections';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(g => ({
    params: { slug: g.data.slug },
    props: { guide: g },
  }));
}

const { guide } = Astro.props;
const frontmatter = guide.data;
const articleSections = await buildArticleSections(guide.body);

const allGuides = await getCollection('guides');
const relatedGuides = frontmatter.related
  .map(slug => allGuides.find(g => g.data.slug === slug))
  .filter(Boolean)
  .map(g => ({ title: g!.data.title, slug: g!.data.slug }));
const routeGuides = allGuides.filter((item) => item.data.category === frontmatter.category).sort((a, b) => a.data.title.localeCompare(b.data.title));
const routeIndex = routeGuides.findIndex((item) => item.data.slug === frontmatter.slug);
const previousGuide = routeIndex > 0 ? { title: routeGuides[routeIndex - 1].data.title, slug: routeGuides[routeIndex - 1].data.slug } : undefined;
const nextGuide = routeIndex >= 0 && routeIndex < routeGuides.length - 1 ? { title: routeGuides[routeIndex + 1].data.title, slug: routeGuides[routeIndex + 1].data.slug } : undefined;

const guideMeta = inferGuideMeta(frontmatter);
const verifiedDate = guide.body.match(/Official sources last checked:\s*(\d{4}-\d{2}-\d{2})/i)?.[1];
const routeLabel = formatRouteLabel(frontmatter.route, frontmatter.category);
const routeHref = frontmatter.category ? `/guides/category/${frontmatter.category}/` : undefined;
---

<GuideLayout
  title={frontmatter.title}
  description={frontmatter.description}
  publishedDate={frontmatter.publishedDate}
  updatedDate={frontmatter.updatedDate}
  slug={frontmatter.slug}
  eyebrow={frontmatter.eyebrow}
  category={frontmatter.category}
  readingTime={frontmatter.readingTime}
  verifiedDate={verifiedDate}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    ...(routeLabel && routeHref ? [{ label: routeLabel, href: routeHref }] : []),
    { label: frontmatter.title },
  ]}
  related={relatedGuides}
  previous={previousGuide}
  next={nextGuide}
  routeHref={routeHref}
  routeLabel={routeLabel}
  country={guideMeta.country}
  exam={guideMeta.exam}
  level={guideMeta.level}
  headings={articleSections.detailedHeadings}
  sections={articleSections}
>
</GuideLayout>
