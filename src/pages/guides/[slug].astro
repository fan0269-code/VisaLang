---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(g => ({
    params: { slug: g.data.slug },
    props: { guide: g },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);
const frontmatter = guide.data;

const allGuides = await getCollection('guides');
const relatedGuides = frontmatter.related
  .map(slug => allGuides.find(g => g.data.slug === slug))
  .filter(Boolean)
  .map(g => ({ title: g!.data.title, slug: g!.data.slug }));
---

<GuideLayout
  title={frontmatter.title}
  description={frontmatter.description}
  publishedDate={frontmatter.publishedDate}
  updatedDate={frontmatter.updatedDate}
  slug={frontmatter.slug}
  eyebrow={frontmatter.eyebrow}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    ...(frontmatter.route
      ? [{ label: frontmatter.route.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()), href: `/#${frontmatter.route}` }]
      : []),
    { label: frontmatter.title },
  ]}
  related={relatedGuides}
  headings={headings}
>
  <Content />
  <section class="official-sources">
    <h2>Official sources</h2>
    <p>Always verify requirements, fees, dates, and accepted exams with the official exam owner or government authority before booking.</p>
  </section>
  <p class="compliance-line">Fees, dates, requirements, and accepted exams change — always confirm with the official exam owner or government authority before booking.</p>
  <p class="last-updated">Last updated: {frontmatter.updatedDate}</p>
</GuideLayout>
