---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(g => ({
    params: { slug: g.data.slug },
    props: { guide: g },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);
const frontmatter = guide.data;

const allGuides = await getCollection('guides');
const relatedGuides = frontmatter.related
  .map(slug => allGuides.find(g => g.data.slug === slug))
  .filter(Boolean)
  .map(g => ({ title: g!.data.title, slug: g!.data.slug }));

const routeLabel = frontmatter.route
  ? frontmatter.route.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
  : '';
---

<GuideLayout
  title={frontmatter.title}
  description={frontmatter.description}
  publishedDate={frontmatter.publishedDate}
  updatedDate={frontmatter.updatedDate}
  slug={frontmatter.slug}
  eyebrow={frontmatter.eyebrow}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    ...(routeLabel ? [{ label: routeLabel, href: `/#${frontmatter.route}` }] : []),
    { label: frontmatter.title },
  ]}
  related={relatedGuides}
  headings={headings}
>
  <Content />
</GuideLayout>
