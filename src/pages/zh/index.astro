---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { zhGermanyA1Guides } from '../../data/zh-germany-a1';
import { guideCategories } from '../../data/guide-taxonomy';
import PageHero from '../../components/PageHero.astro';
import TrustNotice from '../../components/TrustNotice.astro';
import RouteSelector from '../../components/RouteSelector.astro';

const guides = await getCollection('guides');

const categories = [
  { name: '德国 A1', slug: 'germany-a1', desc: '家庭团聚与配偶团聚语言证明' },
  { name: '德国 B1+', slug: 'germany-b1', desc: '永居、工作与入籍路径' },
  { name: 'TestDaF', slug: 'germany-testdaf', desc: '德国大学申请语言考试' },
  { name: '英国签证英语', slug: 'uk', desc: 'UKVI、SELT 与入籍英语' },
  { name: '意大利入籍', slug: 'italy', desc: 'CILS、CELI、PLIDA 选择' },
  { name: '西班牙入籍', slug: 'spain', desc: 'DELE 与 CCSE 路线' },
];

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VisaLang',
  url: 'https://visalang.org/zh/',
  description: 'VisaLang 帮助用户根据签证、永居、入籍、留学或职业注册需求，找到正确的语言考试路径。',
  inLanguage: 'zh-CN',
};
---

<BaseLayout
  title="签证、永居、入籍语言考试路径导航"
  description="VisaLang 帮助用户根据签证、永居、入籍、留学或职业注册需求，找到正确的语言考试路径、官方要求、报名材料和备考方向。"
  canonicalURL="https://visalang.org/zh/"
  lang="zh-CN"
  alternates={[
    { lang: 'en', href: 'https://visalang.org/' },
    { lang: 'zh-CN', href: 'https://visalang.org/zh/' },
    { lang: 'x-default', href: 'https://visalang.org/' },
  ]}
  jsonLD={jsonLD}
>
  <main class="site-main site-main--home">
    <PageHero eyebrow="签证、永居与入籍语言考试" title="先判断路线，再决定报哪一场语言考试" description="确认目的与接收材料的机构，再核验准确的语言证明。" primary={{ href: '/zh/germany-family-reunion-a1/', label: '先看德国 A1 中文路线' }} secondary={{ href: '#zh-guides', label: '浏览中文核心指南' }} />
    <TrustNotice items={['官方来源优先', '要求因路线而异', '报名前务必再次核验']} />
    <section class="content-section" aria-labelledby="zh-purpose-title"><div class="section-header"><h2 id="zh-purpose-title">你准备办理什么？</h2><p>目前德国 A1 家庭团聚有完整中文路径，其余入口会明确进入英文页面。</p></div><RouteSelector locale="zh-CN" /></section>
    <div class="stat-grid"><div class="stat-card"><span class="stat-value">{guides.length + zhGermanyA1Guides.length}</span><span class="stat-label">中英文指南</span></div><div class="stat-card"><span class="stat-value">{guideCategories.length}</span><span class="stat-label">路线分类</span></div><div class="stat-card"><span class="stat-value">官方优先</span><span class="stat-label">内容原则</span></div></div>

    <section class="section-inner content-section compact">
      <div class="feature-route feature-route-grid" aria-labelledby="zh-focus-title">
      <div>
        <p class="eyebrow">当前优先方向</p>
        <h2 id="zh-focus-title">德国配偶团聚 / 家庭团聚 A1</h2>
        <p>这是目前最完整的中文决策路径：从“是否真的需要 A1”开始，依次处理证书选择、报名、材料、备考和重考缓冲。不要先被“最近考位”或“哪个简单”带着走。</p>
      </div>
      <div class="stacked-actions">
        <a class="primary-action" href="/zh/germany-family-reunion-a1/">进入中文专题</a>
        <a class="secondary-action" href="/zh/guides/goethe-a1-30-day-study-plan/">查看 30 天备考计划</a>
      </div>
      </div>
    </section>

    <section class="section-inner content-section compact">
      <div class="route-finder">
        <div class="finder-copy">
          <p class="eyebrow">中文用户怎么使用本站</p>
          <h2>把指南当作提问清单，不当作官方结论。</h2>
          <p>先确定申请地、目的和时间节点；再去德国使领馆、BAMF、Goethe、telc 或当地考点页面核验。费用、日期、考点、证书接受范围和豁免条件都可能变化。</p>
        </div>
        <ol class="finder-steps">
          <li><span class="step-number">01</span><span><strong>先看是否适用。</strong><br />不要因为别人需要 A1，就跳过自己的使领馆或主管机关清单。</span></li>
          <li><span class="step-number">02</span><span><strong>再比证书与考点。</strong><br />确认准确的考试名称、报名姓名、费用、出分和退改规则。</span></li>
          <li><span class="step-number">03</span><span><strong>保存官方记录。</strong><br />保留网页、咨询回复、报名确认和查看日期。</span></li>
        </ol>
      </div>
    </section>

    <section class="section-inner content-section" id="zh-guides">
      <div class="section-header">
        <h2>德国 A1 中文核心指南</h2>
        <p>先覆盖中文用户最需要的 5 个问题：是否需要 A1、Goethe vs telc、报名、材料和备考。</p>
      </div>
      <div class="guide-related-grid">
        {zhGermanyA1Guides.map(g => (
          <a href={g.href} class="article-card">
            <p class="card-category">德国 A1 中文指南</p>
            <h3>{g.title}</h3>
            <p class="card-meta">{g.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section-inner content-section">
      <div class="section-header">
        <h2>按路线浏览</h2>
        <p>除德国 A1 中文核心路径外，其它路线暂时仍进入英文资料库，作为路线概览使用；不要把英文 starter guide 当作对个人签证、入籍或职业路径的最终判断。</p>
      </div>
      <div class="route-grid">
        {categories.map(cat => {
          const count = guides.filter(g => g.data.category === cat.slug).length;
          return (
            <a href={`/guides/category/${cat.slug}/`} class="route-card">
              <span>{cat.name}</span>
              <strong>{cat.desc}</strong>
              <small>{count} 篇指南</small>
            </a>
          );
        })}
      </div>
    </section>
  </main>
</BaseLayout>
