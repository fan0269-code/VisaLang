---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { zhGermanyA1Guides, zhCoreOfficialSources } from '../../data/zh-germany-a1';
import RouteProgress from '../../components/RouteProgress.astro';

const canonicalURL = 'https://visalang.org/zh/germany-family-reunion-a1/';
const updatedDate = zhGermanyA1Guides.reduce((latest, guide) => guide.updatedDate > latest ? guide.updatedDate : latest, '2026-07-09');
const routeSteps = [
  { title: '确认是否需要 A1', status: 'current', preparation: '准备申请地、家庭团聚类型、负责个案的德国使领馆或主管机关，以及需要核验的豁免问题。', guide: { href: '/zh/guides/german-family-reunion-language-requirement/', label: '查看要求指南' } },
  { title: '确认接受的证明', status: 'next', preparation: '向负责机关核对准确的成人证书、等级、考试版本和材料形式。', guide: { href: '/zh/guides/goethe-a1-germany-family-reunion/', label: '核验可接受证明' } },
  { title: '比较考试选项', status: 'next', preparation: '只比较已经被主管机关确认可用的考试，不把品牌知名度当作接受证明。', guide: { href: '/zh/guides/goethe-a1-vs-telc-a1/', label: 'Goethe 与 telc' } },
  { title: '核验考点与报名', status: 'next', preparation: '从考试方入口核验授权考点，再确认准确考试、姓名、证件、费用、日期、退改和出证流程。', guide: { href: '/zh/guides/goethe-a1-test-centers/', label: '核验官方考点' } },
  { title: '制定时间线', status: 'next', preparation: '只使用自己持有或负责机关、所选考点当前确认的考试、出分、取证和材料节点。', guide: { href: '/zh/guides/german-a1-exam-booking-timeline/', label: '倒排报名时间线' } },
  { title: '准备材料', status: 'next', preparation: '把报名、考试当天和签证文件中的语言证明要求分开核对。', guide: { href: '/zh/guides/german-a1-documents-checklist/', label: '材料清单' } },
  { title: '使用官方资源学习', status: 'next', preparation: '在要求、证明、考点、报名和时间线明确后，再安排听说读写练习。', guide: { href: '/zh/guides/goethe-a1-30-day-study-plan/', label: '备考计划' } },
  { title: '递交前复核或进入复考分支', status: 'next', preparation: '递交前重新确认接受范围和文件形式；首次未通过时，另看 Goethe A1 复考（英文指南）。', guide: { href: '/guides/goethe-a1-retake-policy/', label: 'Goethe A1 复考（英文指南）' } },
] as const;
const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'zh-CN',
  mainEntity: [
    {
      '@type': 'Question',
      name: '德国配偶团聚一定要 A1 吗？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '是否需要 A1、是否适用个案例外以及接受哪种证明，要以负责你申请的德国使领馆或主管机关当前要求为准。',
      },
    },
    {
      '@type': 'Question',
      name: 'Goethe A1 和 telc A1 应该如何比较？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '先确认主管机关可能接受的准确证明，再比较考试产品、官方考点和本地报名条件；品牌本身不能替代接受确认。',
      },
    },
  ],
};
---

<BaseLayout
  title="德国 A1 家庭团聚中文专题"
  description="面向中文用户的德国配偶团聚 A1 路线：依次核验要求、可接受证明、考试、官方考点、报名时间线、材料和学习计划。"
  canonicalURL={canonicalURL}
  lang="zh-CN"
  alternates={[
    { lang: 'zh-CN', href: canonicalURL },
    { lang: 'en', href: 'https://visalang.org/germany-family-reunion-a1/' },
    { lang: 'x-default', href: 'https://visalang.org/germany-family-reunion-a1/' },
  ]}
  jsonLD={jsonLD}
>
  <main class="page-shell">
    <article class="guide-article route-hub-page">
      <p class="eyebrow">德国 · 配偶团聚 · A1</p>
      <h1>德国 A1 家庭团聚中文专题</h1>
      <p class="guide-summary">如果你正在准备德国配偶团聚或家庭团聚，先别急着报名考试。先确认负责机关和 A1 要求，再确认可接受证明、考试产品、官方考点、报名时间线和材料；学习计划与复考分支放在这些核验之后。</p>

      <div class="guide-trustbar" aria-label="官方核验提示">
        <span>最后更新：<time datetime={updatedDate}>{updatedDate}</time></span>
        <span>本文不替代德国使领馆、BAMF、Goethe、telc 官方页面；不确定处请以官方最新要求为准。</span>
      </div>

      <h2>快速路线答案</h2>
      <p>先确认 A1 是否适用于你的个案；再确认主管机关接受什么证明；最后才比较 Goethe、telc、考位、费用和备考时间。任何一步没有官方依据，都不要急着付款。</p>

      <h2>谁应该从这里开始</h2>
      <p>适合正在中国或其他申请地准备德国配偶团聚、家庭团聚，尚未把语言要求、证书、报名和递签时间线理清的用户。若你已经收到使领馆的个案补件或书面说明，也可以用本专题逐项核对下一步。</p>

      <h2>谁应该先核对豁免</h2>
      <p>如果你听说自己“可能不需要 A1”，先不要把经验帖当结论。团聚类型、德国一方身份、申请地和材料清单都可能影响判断。请先看负责你个案的德国使领馆或主管机关最新说明。</p>

      <h2>先回答中文用户最常见的几个问题</h2>
      <h3>德国配偶团聚到底要不要 A1？</h3>
      <p>很多配偶团聚路径会要求申请人证明基础德语能力，但不能只听“别人也这么办”。是否需要 A1、是否符合豁免、需要哪种证明，取决于你的关系类型、申请地、德国一方身份、当地使领馆文件清单和当前政策。先看官方清单，再决定考试。</p>

      <h3>Goethe A1 和 telc A1 应该如何比较？</h3>
      <p>先由主管机关确认可能适用的准确证明，再核对证书名称、考试等级、官方考点、材料形式和本地执行规则。不要只用品牌知名度或“哪个更容易”做决定。</p>

      <h3>人在中国怎么报名？</h3>
      <p>先找 Goethe-Institut 或对应官方考点页面，查看当前城市、日期、费用、证件、报名方式、退改规则和出分时间。本文不会编造费用或考试日期，因为这些信息最容易变化。</p>

      <h3>证书多久有效？如果没通过怎么办？</h3>
      <p>证书是否仍被接受、是否要求特定出具时间、再次报名条件和材料安排，都要分别向负责机关、考试主办方和当地考点核验。首次未通过时，用当前考点信息重新计算下一步，不预设复考间隔。</p>

      <h2 id="zh-guides">中文核心指南</h2>
      <div class="guide-related-grid">
        {zhGermanyA1Guides.map((guide) => (
          <a class="article-card" href={guide.href}>
            <p class="card-category">德国 A1 中文指南</p>
            <h3>{guide.title}</h3>
            <p class="card-meta">{guide.description}</p>
          </a>
        ))}
      </div>

      <h2>哪些信息不能只信中介或经验帖</h2>
      <ul>
        <li>当前是否需要 A1，以及你的个案是否可能豁免。</li>
        <li>Goethe A1、telc A1 或其他证书是否被你的主管机关接受。</li>
        <li>考试费用、日期、考点名额、证件规则、退改规则和出分时间。</li>
        <li>签证材料清单里对语言证明原件、复印件、翻译件或有效期的要求。</li>
      </ul>

      <h2>按这个顺序推进</h2>
      <RouteProgress steps={routeSteps} current={0} routeId="zh-germany-family-reunion-a1" locale="zh-CN" />

      <h2>暂时只有英文的补充页面</h2>
      <ul>
        <li><a href="/guides/goethe-a1-pre-booking-checklist/">Goethe A1 付款前检查（英文指南）</a>：在付款前复核要求、准确考试、考点和本地条款。</li>
        <li><a href="/guides/goethe-a1-official-links-practice-resources/">Goethe A1 官方练习资源（英文指南）</a>：确认考试与时间线后再选择官方练习入口。</li>
        <li><a href="/guides/goethe-a1-retake-policy/">Goethe A1 复考（英文指南）</a>：仅在首次未通过后进入这个条件分支。</li>
        <li><a href="/tools/timeline-calculator/">时间线规划器（英文工具）</a>：只输入自己持有或官方确认的节点。</li>
      </ul>

      <h2>官方核验入口</h2>
      <p>这组中文内容的作用是帮你组织问题，不是替你判断政策。每次报名或递签前，都要重新核验官方信息。</p>
      <ul>
        {zhCoreOfficialSources.map((source) => (
          <li><a href={source.href}>{source.name}</a></li>
        ))}
      </ul>

      <p><a class="primary-action" href="/zh/guides/german-family-reunion-language-requirement/">从“是否需要 A1”开始</a></p>
      <p><a class="secondary-action" href="/contact/">发现官方信息变化？提交纠错来源</a></p>
    </article>
  </main>
</BaseLayout>
