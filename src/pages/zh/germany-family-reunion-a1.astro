---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { zhGermanyA1Guides, zhCoreOfficialSources } from '../../data/zh-germany-a1';
import RouteProgress from '../../components/RouteProgress.astro';

const canonicalURL = 'https://flowlight.me/zh/germany-family-reunion-a1/';
const routeSteps = [
  { title: '确认是否需要 A1', status: 'current', preparation: '准备申请地、家庭团聚类型、负责个案的德国使领馆或主管机关，以及需要核验的豁免问题。', guide: { href: '/zh/guides/german-family-reunion-language-requirement/', label: '查看要求指南' } },
  { title: '确认接受的证明', status: 'next', preparation: '核对准确的成人证书、等级、考试版本和材料形式。', guide: { href: '/zh/guides/goethe-a1-vs-telc-a1/', label: '比较证书' } },
  { title: '比较考试选项', status: 'next', preparation: '只比较已经被主管机关确认可用的考试，不把品牌知名度当作接受证明。', guide: { href: '/zh/guides/goethe-a1-vs-telc-a1/', label: 'Goethe 与 telc' } },
  { title: '核验考点与报名', status: 'next', preparation: '核验授权考点、姓名拼写、证件、费用、日期、退改和出分。', guide: { href: '/zh/guides/goethe-a1-booking-mistakes/', label: '报名检查' } },
  { title: '制定时间线', status: 'next', preparation: '只使用当地考点确认的出分、证书寄送和重考时间。', guide: { href: '/zh/guides/goethe-a1-30-day-study-plan/', label: '准备计划' } },
  { title: '准备考试与材料', status: 'next', preparation: '把考试当天材料与签证文件中的语言证明要求分开核对。', guide: { href: '/zh/guides/german-a1-documents-checklist/', label: '材料清单' } },
  { title: '递交前再次核验', status: 'next', preparation: '递交前重新确认接受范围、文件形式和当前官方要求。' },
] as const;
const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'zh-CN',
  mainEntity: [
    {
      '@type': 'Question',
      name: '德国配偶团聚一定要 A1 吗？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '很多配偶团聚申请会涉及基础德语 A1 证明，但是否适用、是否有豁免、接受哪种证书，要以负责你个案的德国使领馆或主管机关最新要求为准。',
      },
    },
    {
      '@type': 'Question',
      name: 'Goethe A1 和 telc A1 哪个更稳？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '更稳的不是品牌本身，而是你的主管机关明确接受、你能按时拿到结果、材料名称和证件规则都符合要求的那一个。',
      },
    },
  ],
};
---

<BaseLayout
  title="德国 A1 家庭团聚中文专题"
  description="面向中文用户的德国配偶团聚 A1 路线：是否需要 A1、Goethe A1 vs telc A1、报名避坑、材料清单、备考计划和官方核验。"
  canonicalURL={canonicalURL}
  lang="zh-CN"
  alternates={[
    { lang: 'zh-CN', href: canonicalURL },
    { lang: 'en', href: 'https://flowlight.me/germany-family-reunion-a1/' },
    { lang: 'x-default', href: 'https://flowlight.me/germany-family-reunion-a1/' },
  ]}
  jsonLD={jsonLD}
>
  <main class="page-shell">
    <article class="guide-article route-hub-page">
      <p class="eyebrow">德国 · 配偶团聚 · A1</p>
      <h1>德国 A1 家庭团聚中文专题</h1>
      <p class="guide-summary">如果你正在准备德国配偶团聚或家庭团聚，先别急着报名考试。正确顺序是：确认自己是否需要 A1，确认哪些证书被接受，再看报名、材料、备考和重考风险。</p>

      <div class="guide-trustbar" aria-label="官方核验提示">
        <span>最后更新：<time datetime="2026-07-09">2026-07-09</time></span>
        <span>本文不替代德国使领馆、BAMF、Goethe、telc 官方页面；不确定处请以官方最新要求为准。</span>
      </div>

      <h2>快速路线答案</h2>
      <p>先确认 A1 是否适用于你的个案；再确认主管机关接受什么证明；最后才比较 Goethe、telc、考位、费用和备考时间。任何一步没有官方依据，都不要急着付款。</p>

      <h2>谁应该从这里开始</h2>
      <p>适合正在中国或其他申请地准备德国配偶团聚、家庭团聚，尚未把语言要求、证书、报名和递签时间线理清的用户。若你已经收到使领馆的个案补件或书面说明，也可以用本专题逐项核对下一步。</p>

      <h2>谁应该先核对豁免</h2>
      <p>如果你听说自己“可能不需要 A1”，先不要把经验帖当结论。团聚类型、德国一方身份、申请地和材料清单都可能影响判断。请先看负责你个案的德国使领馆或主管机关最新说明。</p>

      <h2>先回答中文用户最常见的几个问题</h2>
      <h3>德国配偶团聚到底要不要 A1？</h3>
      <p>很多配偶团聚路径会要求申请人证明基础德语能力，但不能只听“别人也这么办”。是否需要 A1、是否符合豁免、需要哪种证明，取决于你的关系类型、申请地、德国一方身份、当地使领馆文件清单和当前政策。先看官方清单，再决定考试。</p>

      <h3>Goethe A1 和 telc A1 哪个更稳？</h3>
      <p>对签证材料来说，“更稳”通常意味着：主管机关接受、证书名称清楚、考试等级和技能覆盖符合要求、出分时间能赶上预约、考点规则和证件要求你能满足。不要只用“哪个更容易”做决定。</p>

      <h3>人在中国怎么报名？</h3>
      <p>先找 Goethe-Institut 或对应官方考点页面，查看当前城市、日期、费用、证件、报名方式、退改规则和出分时间。本文不会编造费用或考试日期，因为这些信息最容易变化。</p>

      <h3>证书多久有效？如果没通过怎么办？</h3>
      <p>证书有效期、是否要求近期成绩、是否接受旧证书、没通过后的重考间隔和能否赶上签证预约，都要以使领馆、考试主办方和当地考点最新规则为准。备考时要给自己留出重考和补材料时间。</p>

      <h2 id="zh-guides">中文核心指南</h2>
      <div class="guide-related-grid">
        {zhGermanyA1Guides.map((guide) => (
          <a class="article-card" href={guide.href}>
            <p class="card-category">德国 A1 中文指南</p>
            <h3>{guide.title}</h3>
            <p class="card-meta">{guide.description}</p>
          </a>
        ))}
      </div>

      <h2>哪些信息不能只信中介或经验帖</h2>
      <ul>
        <li>当前是否需要 A1，以及你的个案是否可能豁免。</li>
        <li>Goethe A1、telc A1 或其他证书是否被你的主管机关接受。</li>
        <li>考试费用、日期、考点名额、证件规则、退改规则和出分时间。</li>
        <li>签证材料清单里对语言证明原件、复印件、翻译件或有效期的要求。</li>
      </ul>

      <h2>按这个顺序推进</h2>
      <RouteProgress steps={routeSteps} current={0} routeId="zh-germany-family-reunion-a1" locale="zh-CN" />

      <h2>官方核验入口</h2>
      <p>这组中文内容的作用是帮你组织问题，不是替你判断政策。每次报名或递签前，都要重新核验官方信息。</p>
      <ul>
        {zhCoreOfficialSources.map((source) => (
          <li><a href={source.href}>{source.name}</a></li>
        ))}
      </ul>

      <p><a class="primary-action" href="/zh/guides/german-family-reunion-language-requirement/">从“是否需要 A1”开始</a></p>
      <p><a class="secondary-action" href="/contact/">发现官方信息变化？提交纠错来源</a></p>
    </article>
  </main>
</BaseLayout>
