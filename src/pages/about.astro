---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { zhGermanyA1Guides } from '../data/zh-germany-a1';
const guides = await getCollection('guides');
const totalGuideCount = guides.length + zhGermanyA1Guides.length;
const updated = '2026-07-02';
const jsonLD = { '@context': 'https://schema.org', '@type': 'AboutPage', name: 'About VisaLang' };
---

<BaseLayout title="About" description="About VisaLang — your independent language-exam navigation site." jsonLD={jsonLD}>
  <main class="page-shell">
    <article class="guide-article narrow-page">
        <p class="eyebrow">About</p>
        <h1>About VisaLang</h1>
        <p class="guide-summary">VisaLang is a bilingual (English / Chinese) language-exam navigation site for the moment before you book an exam or submit a document that may require language proof.</p>

        <h2>What we do</h2>
        <p>We research official sources, organize the information, add safe preparation guidance, and help you identify what to verify before you pay for an exam. We currently cover <strong>{totalGuideCount} English and Chinese guides</strong> across 11 country routes.</p>

        <h2>What we do not do</h2>
        <ul>
          <li>We do not own exams, issue certificates, or verify results.</li>
          <li>We do not provide legal, financial, or immigration advice.</li>
          <li>We do not book exams on your behalf.</li>
          <li>We do not publish leaked questions or copied real exam items.</li>
        </ul>

        <h2>Why we started with Germany A1</h2>
        <p>Germany A1 family reunion is where a reader can lose time or money by making a decision in the wrong order: a requirement may not apply in every case; a certificate must match the receiving authority; and an exam date is only useful if the centre, ID, result, and document timeline work together. We built this route first as a practical decision sequence, then use the same official-first method for other routes.</p>

        <h2>How we choose what to deepen</h2>
        <p>We prioritize pages where a reader must choose between routes, verify an official requirement, protect a deadline, or avoid an expensive booking mistake. A route overview may remain a starter guide until we can support it with the same depth and source discipline as Germany A1.</p>

        <h2>Our approach</h2>
        <ul>
          <li><strong>Official-first.</strong> Every guide links to the official exam owner or government authority.</li>
          <li><strong>Safe preparation.</strong> We publish original practice guidance, never leaked questions.</li>
          <li><strong>Up-to-date.</strong> Every guide shows a Last Updated date.</li>
          <li><strong>Transparent.</strong> Affiliate relationships are clearly labeled. We never imply official endorsement.</li>
        </ul>

        <h2>Routes we cover</h2>
        <ul>
          <li>German family reunion, settlement, work, and university exams (Goethe, telc, TestDaF)</li>
          <li>UK visa and citizenship English tests (IELTS UKVI, LanguageCert SELT)</li>
          <li>Canada French immigration exams (TEF Canada, TCF Canada, TCF IRN)</li>
          <li>Italian, Spanish, Portuguese, Dutch, Finnish, and French citizenship and residence language exams</li>
        </ul>

        <h2>Our editorial standards</h2>
        <p>See our <a href="/editorial-policy/">Editorial Policy</a> for how we research and maintain content.</p>

        <h2>Contact</h2>
        <p>Found an error or have a suggestion? Visit our <a href="/contact/">contact page</a>.</p>

        <h2>Updates, corrections, and Chinese coverage</h2>
        <p>We update a page when an official source changes, a link breaks, or a reader provides a traceable correction. We record a Last Updated date but still ask readers to verify time-sensitive facts. Chinese coverage currently focuses on the Germany A1 family-reunion core path; it is written for Chinese user questions rather than presented as a full-site line-by-line translation.</p>

        <h2>Important verification boundary</h2>
        <p>VisaLang provides independent, informational guidance only. We are not official and do not provide legal or immigration advice. Before booking or filing, verify your exact requirement with the local German mission or competent authority, and—where relevant—the school, employer, professional body, exam owner, or authorised test centre.</p>
        <p class="compliance-line">VisaLang is an independent publication. We are not a government authority, exam owner, immigration lawyer, or visa agency.</p>
        <p class="last-updated">Last updated: {updated}</p>
    </article>
  </main>
</BaseLayout>
