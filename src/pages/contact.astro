---
import BaseLayout from '../layouts/BaseLayout.astro';
const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact VisaLang',
  description: 'How to reach VisaLang with corrections, suggestions, or partnership inquiries.',
};
---

<BaseLayout title="Contact" description="Contact VisaLang with content corrections, official-source updates, partnership inquiries, or feedback about language-exam route guides." jsonLD={jsonLD}>
  <main class="page-shell">
    <article class="guide-article narrow-page">
        <h1>Contact VisaLang</h1>
        <p>We welcome corrections, content suggestions, and partnership inquiries. Before reaching out, please check whether your question is already answered on our site.</p>

        <h2>Content corrections</h2>
        <p>If you find an outdated fee, broken link, or incorrect requirement, email us with the page URL, the precise sentence or section, the official source URL, and the date you checked it. This lets us prioritize a high-risk correction before a general suggestion.</p>
        <p>Corrections affecting an official requirement, accepted certificate, fee, date, centre, ID rule, result process, or misleading claim take priority. We cannot promise a response time or confirm an individual outcome.</p>

        <h2>Partnership inquiries</h2>
        <p>If you offer language tutoring, exam preparation, or another relevant service and would like to discuss a partnership, include your organisation, website, the exact routes served, countries or centres covered, pricing model, and any commercial relationship you propose. A partnership inquiry does not change editorial coverage or official-source conclusions.</p>

        <h2>What we cannot help with</h2>
        <ul>
          <li>We are not an exam booking service — please book through the official exam provider.</li>
          <li>We are not immigration lawyers — we cannot assess your visa eligibility or provide legal advice.</li>
          <li>We are not exam authorities — we cannot issue, verify, or replace certificates.</li>
          <li>We cannot submit an exam booking, decide a visa or immigration case, or tell you that a certificate will definitely be accepted.</li>
          <li>We do not provide leaked questions, real exam answers, “guaranteed pass” material, or services designed to bypass exam rules.</li>
        </ul>

        <p><strong>Email:</strong> hello@flowlight.me</p>
        <p class="last-updated">Last updated: 2026-07-02</p>
    </article>
  </main>
</BaseLayout>
