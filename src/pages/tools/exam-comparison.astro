---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolResultSupport from '../../components/tools/ToolResultSupport.astro';
import { examComparisonOptions } from '../../data/route-tools';
---

<ToolLayout eyebrow="Planning aid, not an acceptance decision" title="Exam Comparison" description="Compare configured verification questions for two A1 exam options. This tool does not rank providers or decide which certificate an authority will accept." current="comparison">
    <div class="tool-workspace">
      <form id="comparison-form" class="tool-form" novalidate>
        <div class="tool-form-heading"><h2>Choose two configured exams</h2><p>Fees, result timing, centre coverage, and acceptance are always local checks—not comparison claims.</p></div>
        <div class="tool-field-grid">
          <label>First exam<select name="first" required><option value="">Select an exam</option>{examComparisonOptions.map((exam) => <option value={exam.id}>{exam.label}</option>)}</select></label>
          <label>Second exam<select name="second" required><option value="">Select an exam</option>{examComparisonOptions.map((exam) => <option value={exam.id}>{exam.label}</option>)}</select></label>
        </div>
        <div class="tool-error-summary" id="comparison-error" data-error-summary role="alert" tabindex="-1" hidden></div>
        <button class="primary-action" type="submit">Compare verification questions</button>
      </form>
      <section id="comparison-result" class="tool-result" hidden aria-live="polite" tabindex="-1">
        <div id="comparison-summary"></div>
        <ToolResultSupport resultId="comparison-summary" />
      </section>
    </div>
</ToolLayout>

<script>
  import { examComparisonDimensions, examComparisonOptions } from '../../data/route-tools';
  import { setupToolForm } from '../../scripts/tool-form';

  const form = document.querySelector<HTMLFormElement>('#comparison-form');
  const resultPanel = document.querySelector<HTMLElement>('#comparison-result');
  const summary = document.querySelector<HTMLElement>('#comparison-summary');

  const controller = form ? setupToolForm(form, {
    persistedNames: ['first', 'second'],
    customError: (field, currentForm) => field.name === 'second' && field.value && field.value === String(new FormData(currentForm).get('first') || '') ? 'Choose two different exams.' : undefined,
  }) : undefined;
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!controller?.validate()) return;
    const data = Object.fromEntries(new FormData(form).entries());
    const first = examComparisonOptions.find((exam) => exam.id === data.first);
    const second = examComparisonOptions.find((exam) => exam.id === data.second);
    if (!first || !second || !summary || !resultPanel) return;
    controller.persist();
    summary.replaceChildren();
    const heading = document.createElement('h2');
    heading.textContent = `${first.label} and ${second.label}`;
    const intro = document.createElement('p');
    intro.textContent = 'This is a structured official-check list, not a recommendation or a statement of acceptance.';
    const tableWrap = document.createElement('div');
    tableWrap.className = 'tool-table-wrap';
    tableWrap.setAttribute('role', 'region');
    tableWrap.setAttribute('aria-label', 'Exam comparison table. Scroll horizontally to view all columns.');
    tableWrap.tabIndex = 0;
    const tableHint = document.createElement('p');
    tableHint.className = 'tool-table-hint';
    tableHint.textContent = 'Scroll left and right to view all comparison columns.';
    const table = document.createElement('table');
    const header = document.createElement('tr');
    ['Configured dimension', first.label, second.label].forEach((label) => { const cell = document.createElement('th'); cell.scope = 'col'; cell.textContent = label; header.append(cell); });
    const head = document.createElement('thead'); head.append(header); table.append(head);
    const body = document.createElement('tbody');
    examComparisonDimensions.forEach((dimension) => {
      const row = document.createElement('tr');
      const dimensionCell = document.createElement('th'); dimensionCell.scope = 'row'; dimensionCell.textContent = dimension.label;
      const sharedCell = document.createElement('td'); sharedCell.colSpan = 2; sharedCell.textContent = dimension.value;
      row.append(dimensionCell, sharedCell); body.append(row);
    });
    const sourcesRow = document.createElement('tr');
    const sourcesLabel = document.createElement('th'); sourcesLabel.scope = 'row'; sourcesLabel.textContent = 'Official exam page';
    sourcesRow.append(sourcesLabel);
    [first, second].forEach((exam) => {
      const cell = document.createElement('td');
      const link = document.createElement('a'); link.href = exam.officialUrl; link.textContent = exam.label; link.rel = 'noreferrer'; link.target = '_blank';
      cell.append(link);
      sourcesRow.append(cell);
    });
    body.append(sourcesRow);
    table.append(body); tableWrap.append(table);
    summary.append(heading, intro, tableHint, tableWrap);
    resultPanel.hidden = false;
    controller.markResult();
    resultPanel.focus();
  });
  if (controller?.restored) form?.requestSubmit();
</script>
