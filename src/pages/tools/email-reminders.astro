---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolResultSupport from '../../components/tools/ToolResultSupport.astro';
import ToolResultPanel from '../../components/ToolResultPanel.astro';
---
<ToolLayout eyebrow="Local planning only" title="Reminder Planner" description="Create a reminder plan for your own calendar, local storage, notes, or printer. No email service is connected." current="reminders">
  <div class="tool-workspace">
    <form id="reminder-form" class="tool-form" novalidate>
      <div class="tool-form-heading"><h2>Create a verification reminder</h2><p>After a successful result, the visible planning fields can be restored from this page’s URL. No email is sent and no account is created.</p></div>
      <div class="tool-field-grid">
        <label>Reminder topic<select name="topic" required><option value="">Select a topic</option><option>Confirm the language requirement</option><option>Check an official test centre</option><option>Review my requirement checklist</option><option>Recalculate my timeline</option></select></label>
        <label>Reminder date<input name="date" type="date" required /></label>
        <label>Route or authority<input name="route" required placeholder="Example: Germany family reunion / local German mission" /></label>
        <label>Official source to recheck<input name="source" type="url" placeholder="https://" /></label>
      </div>
      <div class="tool-error-summary" id="reminder-error" data-error-summary role="alert" tabindex="-1" hidden></div>
      <button class="button button--primary" type="submit">Create reminder plan</button>
    </form>
    <ToolResultPanel id="reminder-result" title="Your reminder plan"><div id="reminder-summary"></div><div class="button-row"><button class="button button--primary" type="button" data-download-ics>Download ICS</button></div><ToolResultSupport resultId="reminder-summary" /></ToolResultPanel>
  </div>
</ToolLayout>
<script>
  import { setupToolForm } from '../../scripts/tool-form';
  const form = document.querySelector<HTMLFormElement>('#reminder-form');
  const panel = document.querySelector<HTMLElement>('#reminder-result');
  const summary = document.querySelector<HTMLElement>('#reminder-summary');
  let reminder = { topic: '', date: '', route: '', source: '' };
  const controller = form ? setupToolForm(form, { persistedNames: ['topic', 'date', 'route', 'source'] }) : undefined;
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!controller?.validate()) return;
    reminder = Object.fromEntries(new FormData(form).entries()) as typeof reminder;
    controller.persist();
    if (!summary || !panel) return;
    summary.replaceChildren();
    const heading = document.createElement('h2'); heading.textContent = reminder.topic;
    const date = document.createElement('p'); date.textContent = `Reminder date: ${reminder.date}`;
    const route = document.createElement('p'); route.textContent = `Route or authority: ${reminder.route}`;
    const source = document.createElement('p'); source.textContent = reminder.source ? `Official source to recheck: ${reminder.source}` : 'Official source: add the responsible authority or provider page before acting.';
    summary.append(heading, date, route, source); panel.hidden = false; controller.markResult(); panel.focus();
  });
  document.querySelector('[data-download-ics]')?.addEventListener('click', () => {
    if (!reminder.date) return;
    const stamp = reminder.date.replaceAll('-', '');
    const escapeIcs = (value: string) => value.replace(/[\\,;]/g, (match) => `\\${match}`).replace(/\n/g, '\\n');
    const ics = ['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//VisaLang//Reminder Planner//EN','BEGIN:VEVENT',`UID:${Date.now()}@visalang.org`,`DTSTART;VALUE=DATE:${stamp}`,`SUMMARY:${escapeIcs(reminder.topic)}`,`DESCRIPTION:${escapeIcs(`Route or authority: ${reminder.route}. Recheck: ${reminder.source || 'responsible official source'}.`)}`,'END:VEVENT','END:VCALENDAR'].join('\r\n');
    const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' }); const link = document.createElement('a'); link.href = URL.createObjectURL(blob); link.download = 'visalang-reminder.ics'; link.click(); URL.revokeObjectURL(link.href);
  });
  if (controller?.restored) form?.requestSubmit();
</script>
