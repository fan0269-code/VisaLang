---
import BaseLayout from '../layouts/BaseLayout.astro';
import RouteSelector from '../components/RouteSelector.astro';
import LastCheckedBadge from '../components/LastCheckedBadge.astro';
import { getCollection } from 'astro:content';
import { guideCategories } from '../data/guide-taxonomy';
import { site } from '../data/site';
import { zhGermanyA1Guides } from '../data/zh-germany-a1';

const guides = await getCollection('guides');
const updated = [...guides].sort((a, b) => b.data.updatedDate.localeCompare(a.data.updatedDate)).slice(0, 3);
const latestReview = updated[0]?.data.updatedDate || site.lastSystemReview;
const totalGuideCount = guides.length + zhGermanyA1Guides.length;
const jsonLD = { '@context': 'https://schema.org', '@type': 'WebSite', name: site.name, url: `${site.url}/`, description: 'Official-source-first language-proof route decisions.' };
---

<BaseLayout title="Find the language proof required for your route" description="Choose a route, identify the language proof to verify, compare exams, and plan your next official check." canonicalURL="https://flowlight.me/" alternates={[{ lang: 'en', href: 'https://flowlight.me/' }, { lang: 'zh-CN', href: 'https://flowlight.me/zh/' }, { lang: 'x-default', href: 'https://flowlight.me/' }]} jsonLD={jsonLD}>
  <main class="site-main site-main--home">
    <header class="od-home-hero">
      <div class="od-home-hero__copy">
        <p class="od-eyebrow">Decision platform</p>
        <h1>Find the right language proof <em>before</em> you book an exam.</h1>
        <p class="od-home-hero__lead">Start with your purpose—family reunion, work, study, settlement, or citizenship—then identify the proof to verify with the authority receiving your file.</p>
        <div class="button-row"><a class="button button--primary" href="/tools/route-finder/">Find my route <span aria-hidden="true">→</span></a><a class="button button--secondary" href="/guides/">Browse guides</a></div>
        <p class="od-home-hero__benefits"><span>✓ Official sources first</span><span>✓ Independent guidance</span></p>
      </div>
      <aside class="od-route-finder" aria-labelledby="finder-title">
        <h2 id="finder-title">Find your starting point</h2><p>Answer a few questions and we’ll point you to the safest next check.</p>
        <div class="od-route-finder__steps"><span><b>1</b>Country</span><i></i><span><b>2</b>Purpose</span><i></i><span><b>3</b>Level</span></div>
        <label class="od-field" for="home-country">Country<select id="home-country"><option value="">Choose a country</option><option value="germany">Germany</option><option value="uk">United Kingdom</option><option value="canada">Canada</option><option value="other">Another country</option></select></label>
        <label class="od-field" for="home-purpose">Purpose<select id="home-purpose"><option value="">Choose a purpose</option><option value="family">Family reunion</option><option value="work">Work</option><option value="study">Study</option><option value="settlement">Settlement or citizenship</option></select></label>
        <div class="od-route-result" data-home-result><small>Recommended starting point</small><strong data-home-result-title></strong><a data-home-result-link href="/tools/route-finder/">Open Route Finder →</a></div>
      </aside>
    </header>
    <div class="od-trust-strip" aria-label="VisaLang trust principles"><span><strong>Official-first</strong>Verify with the receiving authority</span><span><strong>Independent</strong>No exam-provider affiliation</span><span><strong>{totalGuideCount} guides</strong>Decision support, not legal advice</span></div>

    <section class="od-section" aria-labelledby="spotlight-title"><div class="od-section__head"><p>Route spotlight</p><h2 id="spotlight-title">Germany A1 family reunion</h2><p>A structured starting path for applicants who need to confirm language proof before booking an exam.</p></div><div class="od-spotlight"><div class="od-spotlight__main"><span class="od-pill">Most developed route</span><h3>Confirm first. Book later.</h3><p>Work through the requirement, accepted proof, exam choice, timeline, documents, and official submission checks in the right order.</p><a class="button button--primary" href="/germany-family-reunion-a1/">View full route →</a></div><ol class="od-spotlight__side"><li>Confirm the requirement</li><li>Identify accepted proof</li><li>Compare exam options</li><li>Plan booking and documents</li></ol></div></section>

    <section class="od-section" aria-labelledby="purpose-title"><div class="od-section__head"><p>Browse routes</p><h2 id="purpose-title">What are you trying to do?</h2><p>Start with the decision that brings you here. The receiving authority or institution sets the rule.</p></div><RouteSelector /></section>

    <section class="od-section" aria-labelledby="tools-title"><div class="od-section__head"><p>Practical tools</p><h2 id="tools-title">Turn checks into a plan</h2><p>Use tools to organise facts you have verified. Unsupported routes stop at a clear official-check boundary.</p></div>
      <div class="tool-grid">
        {site.tools.slice(0, 4).map((tool) => <a class="route-card" href={tool.href}><strong>{tool.label}</strong><small>{tool.description}</small></a>)}
      </div>
      <div class="button-row"><a class="button button--secondary" href="/tools/">View all tools</a></div>
    </section>

    <section class="od-section" aria-labelledby="how-title"><div class="od-section__head"><p>How it works</p><h2 id="how-title">A calmer way to decide</h2></div>
      <ol class="route-progress">
        <li class="route-progress__item"><div class="route-progress__number">1</div><div><h3>Identify the receiving organisation</h3><p>Start with the mission, authority, university, employer, regulator, or other organisation that receives your proof.</p></div></li>
        <li class="route-progress__item"><div class="route-progress__number">2</div><div><h3>Confirm the exact proof</h3><p>Verify the certificate, level, exam version, document format, and any exemption before comparing providers.</p></div></li>
        <li class="route-progress__item"><div class="route-progress__number">3</div><div><h3>Plan and verify again</h3><p>Use official centre details for dates, fees, ID, results, and cancellation. Recheck before payment and submission.</p></div></li>
      </ol>
    </section>

    <section class="od-section" aria-labelledby="updated-title"><div class="od-section__head"><p>Latest guidance</p><h2 id="updated-title">Recently updated</h2><p>{totalGuideCount} English and Chinese guides across {guideCategories.length} route categories. Counts and dates come from the guide data sources.</p><LastCheckedBadge date={latestReview} /></div>
      <div class="guide-related-grid">{updated.map((guide) => <a class="article-card" href={`/guides/${guide.data.slug}/`}><h3>{guide.data.title}</h3><p class="card-meta">{guide.data.description}</p><span class="last-checked">Updated {guide.data.updatedDate}</span></a>)}</div>
    </section>

    <section class="content-section verification-alert verification-alert--success" aria-labelledby="principle-title"><strong id="principle-title">Our verification principle</strong><div><p>VisaLang explains how to check a route. It does not replace the decision of an authority, institution, exam owner, or authorised centre.</p><p><a href="/editorial-policy/">Read the editorial and correction policy</a></p></div></section>
  </main>
  <script is:inline>
    const country = document.querySelector('#home-country'); const purpose = document.querySelector('#home-purpose'); const result = document.querySelector('[data-home-result]');
    const update = () => { if (!country?.value || !purpose?.value) return; const germanyFamily = country.value === 'germany' && purpose.value === 'family'; result.dataset.visible = 'true'; result.querySelector('[data-home-result-title]').textContent = germanyFamily ? 'Germany A1 family reunion route' : 'Prepare an official route check'; result.querySelector('[data-home-result-link]').href = germanyFamily ? '/germany-family-reunion-a1/' : '/tools/route-finder/'; };
    country?.addEventListener('change', update); purpose?.addEventListener('change', update);
  </script>
</BaseLayout>
