---
import BaseLayout from '../layouts/BaseLayout.astro';
import RouteSelector from '../components/RouteSelector.astro';
import GuideStatusBadge from '../components/GuideStatusBadge.astro';
import { getCollection } from 'astro:content';
import { resolveGuideContentStatus } from '../data/source-review';
import { guideCategories } from '../data/guide-taxonomy';
import { site } from '../data/site';
import { zhGermanyA1Guides } from '../data/zh-germany-a1';

const guides = await getCollection('guides');
const updated = [...guides]
  .sort((a, b) => b.data.updatedDate.localeCompare(a.data.updatedDate))
  .slice(0, 3)
  .map((guide) => ({ ...guide, status: resolveGuideContentStatus(guide.data) }));
const totalGuideCount = guides.length + zhGermanyA1Guides.length;
const jsonLD = { '@context': 'https://schema.org', '@type': 'WebSite', name: site.name, url: `${site.url}/`, description: 'Official-source-first language-proof route decisions.' };
---

<BaseLayout title="Find the language proof required for your route" description="Choose a route, identify the language proof to verify, compare exams, and plan your next official check." canonicalURL="https://visalang.org/" alternates={[{ lang: 'en', href: 'https://visalang.org/' }, { lang: 'zh-CN', href: 'https://visalang.org/zh/' }, { lang: 'x-default', href: 'https://visalang.org/' }]} jsonLD={jsonLD}>
  <main class="site-main site-main--home">
    <header class="home-hero">
      <div class="home-hero__copy">
        <p class="eyebrow">Official-source-first</p>
        <h1>Find the right language proof before you book an exam.</h1>
        <p>VisaLang turns a language-proof question into a route you can verify: purpose, level, accepted exam, official source, and next action.</p>
        <div class="home-hero__actions">
          <a class="button button--primary" href="/tools/route-finder/">Start with Route Finder <span aria-hidden="true">→</span></a>
          <a class="button button--secondary" href="/guides/">Browse guides</a>
        </div>
        <div class="home-hero__note" aria-label="VisaLang working principles">
          <div class="signal"><strong>Route first</strong><span>Avoid choosing an exam before the receiving organisation is clear.</span></div>
          <div class="signal"><strong>Verify next</strong><span>High-change facts stay tied to official sources.</span></div>
          <div class="signal"><strong>Clear boundary</strong><span>We do not replace authorities, institutions, or exam owners.</span></div>
        </div>
      </div>
      <aside class="route-console" aria-label="Route starting point">
        <div class="route-console__head">
          <p class="console-label">Route starting point</p>
          <h2>Start with the Germany A1 family reunion route</h2>
          <p>This is the most developed route. It does not produce a policy decision — it identifies the next question to verify.</p>
        </div>
        <div class="route-console__body">
          <div class="result-card">
            <b>Germany A1 family reunion</b>
            <p>Next: verify whether the receiving organisation specifies a language level, accepted exam, certificate format, or validity rule.</p>
            <div class="result-actions">
              <a class="mini-button" href="/germany-family-reunion-a1/">Open route</a>
              <a class="mini-button" href="/tools/route-finder/">Use full tool</a>
            </div>
          </div>
        </div>
      </aside>
    </header>

    <hr class="rule" />

    <section class="section" aria-labelledby="stage-title">
      <h2 class="section-title" id="stage-title">Break the decision into four practical stages</h2>
      <div class="lane-grid">
        <ol class="stage-list">
          <li class="stage-card"><div><h3>Identify the receiving organisation</h3><p>Start with the authority, institution, employer, regulator, or exam body that will receive your proof.</p><a href="/tools/route-finder/">Choose a purpose</a></div></li>
          <li class="stage-card"><div><h3>Confirm the proof level</h3><p>Check the source that receives your file before treating any A1, B1, B2, or other level as suitable.</p><a href="/guides/">Browse level guides</a></div></li>
          <li class="stage-card"><div><h3>Compare accepted exams</h3><p>The same level can map to different certificates. Acceptance depends on the receiving organisation.</p><a href="/tools/exam-comparison/">Compare exams</a></div></li>
          <li class="stage-card"><div><h3>Verify before acting</h3><p>Recheck centre status, dates, fees, ID rules, result timing, and submission requirements before payment.</p><a href="/tools/checklist-generator/">Build a checklist</a></div></li>
        </ol>
        <aside class="sidebar-panel">
          <h3>VisaLang organises the route. It does not decide the rule.</h3>
          <p>The interface keeps the boundary visible: no legal or administrative conclusions, no promise that a certificate will be accepted.</p>
          <ul class="check-list">
            <li>High-change facts become verification tasks.</li>
            <li>Every module ends with a next action.</li>
            <li>Tools, guides, and official-source checks form one loop.</li>
          </ul>
        </aside>
      </div>
    </section>

    <hr class="rule" />

    <section class="section" aria-labelledby="resources-title">
      <h2 class="section-title" id="resources-title">Enter through tools or guides</h2>
      <p class="section-lede">Tools narrow the route. Guides explain the boundary, official checks, and supporting evidence.</p>
      <div class="resource-layout">
        <div class="resource-lead">
          <h3>Use a tool when the route is unclear.</h3>
          <p>If you do not know which language proof matters, begin with the route finder instead of reading a long list first.</p>
          <div class="button-row"><a class="button button--primary" href="/tools/route-finder/">Open Route Finder</a></div>
        </div>
        <div class="resource-list">
          <a class="resource-link" href="/tools/route-finder/"><div><h3>Route Finder</h3><p>Start from purpose, country, and current instruction status.</p></div><span>Open</span></a>
          <a class="resource-link" href="/guides/"><div><h3>Guide library</h3><p>Filter explainers by purpose, route, exam, level, and verification status.</p></div><span>Browse</span></a>
          <a class="resource-link" href="/germany-family-reunion-a1/"><div><h3>Germany A1 route</h3><p>The most developed route for staged requirement, exam, booking, and document checks.</p></div><span>View</span></a>
        </div>
      </div>
    </section>

    <hr class="rule" />

    <section class="section section--tight" aria-labelledby="purpose-title">
      <h2 class="section-title" id="purpose-title">What are you trying to do?</h2>
      <p class="section-lede">Start with the decision that brings you here. The receiving authority or institution sets the rule.</p>
      <RouteSelector />
    </section>

    <section class="section" aria-labelledby="updated-title"><div class="section-header"><p class="eyebrow">Latest guidance</p><h2 id="updated-title">Recently updated</h2><p>{totalGuideCount} English and Chinese guides across {guideCategories.length} route categories. Counts and editing dates come from the guide data sources.</p></div>
      <div class="guide-related-grid">{updated.map((guide) => <a class="article-card" href={`/guides/${guide.data.slug}/`}><GuideStatusBadge status={guide.status} /><h3>{guide.data.title}</h3><p class="card-meta">{guide.data.description}</p><span class="last-checked">Updated {guide.data.updatedDate}</span></a>)}</div>
    </section>

    <section class="section section--tight" aria-labelledby="trust-title">
      <h2 class="section-title" id="trust-title">Trust comes from clear boundaries</h2>
      <p class="section-lede">The product should not make dramatic promises. It should show what can be organised here and what must be verified elsewhere.</p>
      <div class="trust-band">
        <div class="trust-item"><b>No invented facts</b><p>When a stable source is missing, VisaLang gives a verification task instead of a false answer.</p></div>
        <div class="trust-item"><b>No official replacement</b><p>Governments, institutions, exam owners, and authorised centres remain the final source.</p></div>
        <div class="trust-item"><b>No pressure tactics</b><p>Stages and checklists reduce uncertainty without pushing users into premature booking.</p></div>
      </div>
    </section>
  </main>
</BaseLayout>
