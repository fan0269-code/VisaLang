---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');
const featured = guides.filter(g => g.data.featured).slice(0, 3);
const latest = guides
  .sort((a, b) => b.data.publishedDate.localeCompare(a.data.publishedDate))
  .slice(0, 6);

const categories = [
  { name: 'Germany A1', slug: 'germany-a1', desc: 'Family reunion language proof' },
  { name: 'Germany B1+', slug: 'germany-b1', desc: 'Settlement, work, citizenship' },
  { name: 'TestDaF', slug: 'germany-testdaf', desc: 'University admissions' },
  { name: 'telc Deutsch', slug: 'germany-telc', desc: 'Work & nursing registration' },
  { name: 'United Kingdom', slug: 'uk', desc: 'UK visa & citizenship English' },
  { name: 'Canada', slug: 'canada', desc: 'TEF/TCF French immigration' },
  { name: 'Italy', slug: 'italy', desc: 'CILS/CELI/PLIDA citizenship' },
  { name: 'Spain', slug: 'spain', desc: 'DELE & CCSE citizenship' },
  { name: 'France', slug: 'france', desc: 'DELF/DALF work & study' },
  { name: 'Finland', slug: 'finland', desc: 'YKI citizenship' },
  { name: 'Netherlands', slug: 'netherlands', desc: 'Inburgering & NT2' },
  { name: 'Portugal', slug: 'portugal', desc: 'CIPLE A2 & Golden Visa' },
];

const stats = [
  { label: 'Guides', value: guides.length },
  { label: 'Routes', value: categories.length },
  { label: 'Countries', value: 11 },
];

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VisaLang',
  url: 'https://flowlight.me/',
  description: 'Find the right language exam for your visa, residency, citizenship, or work-registration path.',
};
---

<BaseLayout title="Find the right language exam for your next move" description="Official-first guides for German, English, French, Italian, Spanish, Dutch, Portuguese, and Finnish language exams — built for visa, residency, citizenship, and work-registration paths." jsonLD={jsonLD}>
  <main>
    <section class="hero">
      <h1>Find the right language exam for your next move</h1>
      <p>Official-first guides for German, English, French, Italian, Spanish, Dutch, Portuguese, and Finnish language exams — built for visa, residency, citizenship, and work-registration paths.</p>
      <a class="primary-action" href="#guides">Browse exam guides</a>
      <div class="hero-stats">
        {stats.map(s => (
          <div class="stat"><span class="stat-value">{s.value}</span><span class="stat-label">{s.label}</span></div>
        ))}
      </div>
    </section>

    {featured.length > 0 && (
      <section class="container" style="padding: 0 24px 48px">
        <h2 class="section-title">Featured guides</h2>
        <div class="guide-related-grid">
          {featured.map(g => (
            <a href={`/guides/${g.data.slug}/`} class="article-card">
              <p class="card-category">{g.data.eyebrow || g.data.category}</p>
              <h3>{g.data.title}</h3>
              <p class="card-meta">{g.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section id="guides" class="container" style="padding: 0 24px 48px">
      <h2 class="section-title">Browse by route</h2>
      <div class="guide-related-grid">
        {categories.map(cat => {
          const count = guides.filter(g => g.data.category === cat.slug).length;
          return (
            <a href={`/guides/?category=${cat.slug}`} class="article-card">
              <p class="card-category">{cat.name}</p>
              <h3>{cat.desc}</h3>
              <p class="card-meta">{count} guide{count !== 1 ? 's' : ''}</p>
            </a>
          );
        })}
      </div>
    </section>

    <section class="container" style="padding: 0 24px 64px">
      <h2 class="section-title">Latest guides</h2>
      <div class="guide-related-grid">
        {latest.map(g => (
          <a href={`/guides/${g.data.slug}/`} class="article-card">
            <p class="card-category">{g.data.eyebrow || g.data.category}</p>
            <h3>{g.data.title}</h3>
            <p class="card-meta">{g.data.updatedDate}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .section-title { text-align: center; font-size: 1.3rem; margin-bottom: 24px; font-family: var(--font-display); color: var(--ink); }
  .hero-stats { display: flex; gap: 32px; justify-content: center; margin-top: 32px; }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat-value { font-size: 2rem; font-weight: 700; color: var(--brand); font-family: var(--font-display); }
  .stat-label { font-size: 0.85rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
  @media (max-width: 680px) { .hero-stats { gap: 20px; } .stat-value { font-size: 1.5rem; } }
</style>
