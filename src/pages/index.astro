---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');
const germanyA1Count = guides.filter(g => g.data.category === 'germany-a1').length;
const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VisaLang',
  url: 'https://flowlight.me/',
  description: 'Independent, informational guidance for choosing and verifying German language proof before an exam booking or application.',
};
---

<BaseLayout
  title="Find the right German language proof before you book an exam"
  description="Independent, official-source-first guidance for choosing German language proof before an exam booking or application."
  canonicalURL="https://flowlight.me/"
  lang="en"
  alternates={[
    { lang: 'en', href: 'https://flowlight.me/' },
    { lang: 'zh-CN', href: 'https://flowlight.me/zh/' },
    { lang: 'x-default', href: 'https://flowlight.me/' },
  ]}
  jsonLD={jsonLD}
>
  <main class="site-main">
    <section class="hero">
      <p class="eyebrow">Independent German language-proof guidance</p>
      <h1>Find the right German language proof before you book an exam.</h1>
      <p>Start with your purpose—family reunion, work, Ausbildung, nursing, university, settlement, or citizenship—then identify the proof to verify before you pay, apply, or submit a document.</p>
      <div class="action-row">
        <a class="primary-action" href="/tools/route-finder/">Find my starting route</a>
        <a class="secondary-action" href="#verification">How to verify a requirement</a>
      </div>
    </section>

    <section class="section-inner content-section compact" aria-labelledby="route-finder-title">
      <div class="route-finder">
        <div class="finder-copy">
          <p class="eyebrow">First step</p>
          <h2 id="route-finder-title">Route Finder</h2>
          <p>Use the Route Finder for an initial direction based on your purpose. It helps you frame the right questions before you choose a test—not confirm that a certificate will be accepted.</p>
          <div class="action-row left">
            <a class="primary-action" href="/tools/route-finder/">Open Route Finder</a>
            <a class="secondary-action" href="/guides/">Browse exam guides</a>
          </div>
        </div>
        <ol class="finder-steps">
          <li><span class="step-number">01</span><span><strong>Name the receiving authority.</strong><br />A German mission, authority, school, employer, or professional body may set the relevant rule.</span></li>
          <li><span class="step-number">02</span><span><strong>Match the exact proof.</strong><br />Check the named certificate and level, not just a familiar exam brand.</span></li>
          <li><span class="step-number">03</span><span><strong>Verify before booking.</strong><br />Confirm current acceptance, local centre, timing, fees, ID, and documents with official sources.</span></li>
        </ol>
      </div>
    </section>

    <section class="section-inner content-section" aria-labelledby="germany-routes-title">
      <div class="section-header">
        <p class="eyebrow">Germany routes</p>
        <h2 id="germany-routes-title">Start with the decision you need to make</h2>
        <p>These guides explain a route and its official checks. They do not replace a decision by the authority receiving your application or document.</p>
      </div>
      <div class="guide-related-grid">
        <a href="/germany-family-reunion-a1/" class="article-card">
          <p class="card-category">Family reunion</p>
          <h3>Germany A1 family reunion</h3>
          <p class="card-meta">Check whether A1 applies, then verify the accepted proof, centre, booking timing, and documents.</p>
        </a>
        <a href="/guides/telc-b1-b2-germany-work-nursing/" class="article-card">
          <p class="card-category">Work, Ausbildung &amp; nursing</p>
          <h3>German proof for professional routes</h3>
          <p class="card-meta">Start with the employer, training provider, regulator, or recognition body that will receive your evidence.</p>
        </a>
        <a href="/guides/testdaf-germany-university-admissions/" class="article-card">
          <p class="card-category">University, settlement &amp; citizenship</p>
          <h3>Choose the authority first</h3>
          <p class="card-meta">University admissions and residence routes can require different evidence; check the exact receiving institution or authority.</p>
        </a>
      </div>
      <p class="action-row"><a class="secondary-action" href="/guides/category/germany-a1/">View Germany guides ({germanyA1Count} A1 guides)</a></p>
    </section>

    <section class="section-inner content-section compact" aria-labelledby="tools-title">
      <div class="feature-route feature-route-grid">
        <div>
          <p class="eyebrow">Free tools</p>
          <h2 id="tools-title">Use a tool to prepare your official check</h2>
          <p>Route Finder, checklists, timelines, and comparisons are being added as informational tools. Their result is a starting point—not an official decision, legal advice, or immigration advice.</p>
        </div>
        <div class="stacked-actions">
          <a class="primary-action" href="/tools/route-finder/">Route Finder</a>
          <a class="secondary-action" href="/tools/checklist-generator/">Pre-booking checklist</a>
          <a class="secondary-action" href="/tools/timeline-calculator/">Timeline planner</a>
        </div>
      </div>
    </section>

    <section id="verification" class="section-inner content-section compact" aria-labelledby="verification-title">
      <div class="route-finder">
        <div class="finder-copy">
          <p class="eyebrow">Independent, informational guidance</p>
          <h2 id="verification-title">Trust the source that receives your file</h2>
          <p>VisaLang is independent and non-official. We explain a safe order for checking language proof, but we are not an exam owner, German authority, law firm, or immigration adviser.</p>
          <p><a class="secondary-action" href="/editorial-policy/">Read our editorial policy</a></p>
        </div>
        <ol class="finder-steps">
          <li><span class="step-number">01</span><span><strong>For visa and residence cases:</strong><br />verify with the local German mission or competent German authority.</span></li>
          <li><span class="step-number">02</span><span><strong>For study and work:</strong><br />verify with the school, university, employer, regulator, or professional body.</span></li>
          <li><span class="step-number">03</span><span><strong>For the exam itself:</strong><br />verify with the exam owner and authorised local test centre before booking.</span></li>
        </ol>
      </div>
    </section>

    <section class="section-inner content-section compact" aria-labelledby="next-step-title">
      <div class="feature-route feature-route-grid">
        <div>
          <p class="eyebrow">Next step</p>
          <h2 id="next-step-title">Choose your level of support transparently</h2>
          <p>Free guidance comes first. Product packs and an informational Route Review will be clearly labelled when available; neither can promise an exam, visa, admission, or acceptance outcome.</p>
        </div>
        <div class="stacked-actions">
          <a class="secondary-action" href="/pricing/">See support options</a>
          <a class="secondary-action" href="/route-review/">About Route Review</a>
          <a class="secondary-action" href="/contact/">Report a correction or ask about partnerships</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
