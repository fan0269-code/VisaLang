---
import ArticleTOC from '../components/ArticleTOC.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const canonicalURL = 'https://visalang.org/germany-b1-settlement-citizenship/';
const description = 'A Germany B1 route for settlement-permit and naturalisation questions: identify the competent authority, verify possible proof, then plan local execution and submission.';
const headings = [
  { text: 'Who decides and what to confirm first', id: 'who-decides', depth: 2 },
  { text: 'Choose the correct route entry', id: 'route-entry', depth: 2 },
  { text: 'Keep language and civic knowledge separate', id: 'separate-evidence', depth: 2 },
  { text: 'Compare only possible proof', id: 'compare-proof', depth: 2 },
  { text: 'Verify the selected centre', id: 'verify-centre', depth: 2 },
  { text: 'Build the timeline from confirmed dates', id: 'build-timeline', depth: 2 },
  { text: 'Finish with a submission recheck', id: 'submission-recheck', depth: 2 },
  { text: 'Optional preparation support', id: 'preparation-support', depth: 2 },
  { text: 'Planning tools and their limits', id: 'tool-boundary', depth: 2 },
];
const corePages = [
  { name: 'Settlement permit and B1', url: '/guides/goethe-b1-germany-settlement-work/' },
  { name: 'Citizenship language proof', url: '/guides/germany-b1-citizenship-language-proof/' },
  { name: 'Language and civic knowledge', url: '/guides/germany-b1-leben-in-deutschland-and-language-proof/' },
  { name: 'DTZ, Goethe B1 and telc B1 comparison', url: '/guides/goethe-b1-vs-telc-b1/' },
  { name: 'Fees and booking verification', url: '/guides/goethe-b1-fees-and-booking/' },
  { name: 'Study plan', url: '/guides/goethe-b1-study-plan/' },
  { name: 'Evidence timeline', url: '/guides/germany-b1-settlement-citizenship-timeline/' },
  { name: 'Submission checklist', url: '/guides/germany-b1-settlement-citizenship-checklist/' },
];
const absoluteUrl = (url: string) => new URL(url, canonicalURL).href;
const jsonLD = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://visalang.org/' },
        { '@type': 'ListItem', position: 2, name: 'Germany B1 settlement and citizenship', item: canonicalURL },
      ],
    },
    {
      '@type': 'CollectionPage',
      name: 'Germany B1 for settlement permits and citizenship',
      description,
      url: canonicalURL,
      inLanguage: 'en',
      hasPart: corePages.map((page) => ({ '@type': 'Article', name: page.name, url: absoluteUrl(page.url) })),
    },
  ],
};
---

<BaseLayout
  title="Germany B1 for settlement permits and citizenship: verify the route first"
  description={description}
  canonicalURL="https://visalang.org/germany-b1-settlement-citizenship/"
  jsonLD={jsonLD}
>
  <main class="page-shell">
    <article class="guide-article route-hub-page">
      <p class="eyebrow">Germany · B1 · settlement and citizenship</p>
      <h1>Germany B1 for settlement permits and citizenship</h1>
      <p class="guide-summary">Start with the authority and legal route that apply to your application. This hub helps you separate language proof from the wider file, compare only relevant exam products, and keep local dates and terms tied to current official sources.</p>

      <div class="guide-trustbar" aria-label="Verification boundary">
        <span>The competent authority decides your route, evidence and outcome.</span>
        <span>VisaLang does not decide eligibility, exemptions, certificate acceptance or application results.</span>
      </div>

      <ArticleTOC headings={headings} />

      <h2 id="who-decides">Who decides and what to confirm first</h2>
      <p>For a settlement-permit question, identify the statutory route and competent local foreigners authority. For naturalisation, use the competent nationality authority. Germany has different settlement routes, and their language thresholds and cross-references are not identical. Do not convert a general B1 statement into a conclusion about your case.</p>
      <p>Save the authority's current page, portal, form or written reply, the route it names, and the date checked. An exam provider can define its product, but it cannot decide whether that proof fits your application.</p>

      <h2 id="route-entry">Choose the correct route entry</h2>
      <div class="guide-related-grid">
        <a class="article-card" href="/guides/goethe-b1-germany-settlement-work/"><p class="card-category">Settlement permit</p><h3>Identify the route before treating B1 as relevant</h3><p>Separate the language question from all other permit conditions.</p></a>
        <a class="article-card" href="/guides/germany-b1-citizenship-language-proof/"><p class="card-category">Naturalisation</p><h3>Keep B1 language evidence inside the wider file</h3><p>Confirm the current evidence and local procedure with the nationality authority.</p></a>
      </div>

      <h2 id="separate-evidence">Keep language and civic knowledge separate</h2>
      <p>B1 language evidence and civic-knowledge evidence answer different questions. The <a href="/guides/germany-b1-leben-in-deutschland-and-language-proof/">Leben in Deutschland guide</a> explains the separation and the limits of the integration-course evidence. Do not assume that one result replaces the other or completes the application.</p>

      <h2 id="compare-proof">Compare only possible proof</h2>
      <p>After the authority identifies possible language evidence, use the <a href="/guides/goethe-b1-vs-telc-b1/">DTZ, Goethe B1 and telc B1 comparison</a>. Compare exact products and document formats, not general recognition claims, anecdotes or an exam brand in isolation.</p>

      <h2 id="verify-centre">Verify the selected centre</h2>
      <p>Use the <a href="/guides/goethe-b1-fees-and-booking/">fees and booking guide</a> to record the selected official or authorised centre, exact product, date, seat, fee scope, identification, cancellation, accessibility, result and certificate process. These local details remain time-sensitive even when this page's source review is current.</p>

      <h2 id="build-timeline">Build the timeline from confirmed dates</h2>
      <p>The <a href="/guides/germany-b1-settlement-citizenship-timeline/">B1 evidence timeline</a> starts from dates supplied by you, the competent authority or the selected centre. It does not calculate residence periods, processing time or eligibility, and it does not insert a default retake or appointment buffer.</p>

      <h2 id="submission-recheck">Finish with a submission recheck</h2>
      <p>Use the <a href="/guides/germany-b1-settlement-citizenship-checklist/">settlement and citizenship checklist</a> as the terminal route step. Compare every note with the authority's current instructions, resolve mismatches, and leave unresolved items open rather than forcing the route back into a loop.</p>

      <h2 id="preparation-support">Optional preparation support</h2>
      <p>Preparation becomes useful only after the exam product is relevant and clear. Start with the <a href="/guides/goethe-b1-study-plan/">adjustable study plan</a>, then use the support page that matches a real gap:</p>
      <ul>
        <li><a href="/guides/goethe-b1-difficulty-analysis/">Difficulty and weak-area analysis</a></li>
        <li><a href="/guides/goethe-b1-listening-deep-dive/">Listening practice</a></li>
        <li><a href="/guides/goethe-b1-mock-exam-routine/">Mock-exam routine</a></li>
        <li><a href="/guides/goethe-b1-speaking-topics/">Speaking practice</a></li>
        <li><a href="/guides/goethe-b1-writing-assessment/">Writing self-check</a></li>
      </ul>

      <h2 id="tool-boundary">Planning tools and their limits</h2>
      <p><a href="/tools/route-finder/">Route Finder</a> can help frame an authority question. The <a href="/tools/exam-comparison/">Exam Comparison</a>, <a href="/tools/timeline-calculator/">Timeline calculator</a> and <a href="/tools/checklist-generator/">Checklist generator</a> organise information you enter; they do not verify acceptance, dates or eligibility.</p>
      <p><a href="/route-review/">Route Review</a> is an information boundary, not legal advice or a decision by the competent authority. Browse all pages in the <a href="/guides/category/germany-b1/">Germany B1 guide collection</a>.</p>

      <section class="official-sources">
        <h2 id="official-sources">Official starting points</h2>
        <ul>
          <li><a href="https://www.gesetze-im-internet.de/aufenthg_2004/__9.html">Residence Act, Section 9</a></li>
          <li><a href="https://www.gesetze-im-internet.de/stag/__10.html">Nationality Act, Section 10</a></li>
          <li><a href="https://www.einbuergerung.de/ablauf.php?l=en">German Government naturalisation process</a></li>
          <li><a href="https://bamf-navi.bamf.de/en/Themen/Behoerden/?typ=ABH">BAMF-NAvI authority locator</a></li>
        </ul>
      </section>
      <p class="compliance-line">Verify current route, evidence, local execution and submission instructions with the competent authority and selected official or authorised centre before acting.</p>
      <p class="last-updated">Last updated: 2026-07-19</p>
    </article>
  </main>
</BaseLayout>
